<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	tools:ignore="AllFilesAccessPolicy,ScopedStorage,ForegroundServicesPolicy,RequestInstallPackagesPolicy">
	
	<!--
		====================================================================
		APP PERMISSIONS
		====================================================================
		
		This section defines all permissions required by the application.
		Permissions are categorized by functionality and Android version requirements.
	-->
	
	<!-- NETWORK PERMISSIONS: Required for internet connectivity and network monitoring -->
	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
	<uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
	
	<!-- NOTIFICATION PERMISSIONS: For displaying notifications and vibration feedback -->
	<!-- POST_NOTIFICATIONS is required for Android 13+ (API 33+) -->
	<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
	<uses-permission android:name="android.permission.VIBRATE" />
	
	<!-- BACKGROUND EXECUTION PERMISSIONS: For background tasks and device restart handling -->
	<uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
	<uses-permission android:name="android.permission.WAKE_LOCK" />
	
	<!-- STORAGE PERMISSIONS: For file management and storage access -->
	<!-- MANAGE_EXTERNAL_STORAGE provides broad file access (requires Play Store justification) -->
	<uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
	
	<!-- LEGACY STORAGE PERMISSIONS: For Android 10 and below compatibility -->
	<!-- maxSdkVersion="32" restricts these to Android 12 and below -->
	<uses-permission
		android:name="android.permission.WRITE_EXTERNAL_STORAGE"
		android:maxSdkVersion="32" />
	<uses-permission
		android:name="android.permission.READ_EXTERNAL_STORAGE"
		android:maxSdkVersion="32" />
	
	<!-- FOREGROUND SERVICE PERMISSIONS: Required for Android 9+ foreground services -->
	<!-- Specific foreground service types must be declared for Android 12+ -->
	<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
	<uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
	<uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
	
	<!-- INSTALLATION PERMISSION: Required for installing downloaded APK files -->
	<uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
	
	<!--
		====================================================================
		APPLICATION CONFIGURATION
		====================================================================
		
		This section defines the main application configuration including
		activities, services, receivers, and providers.
	-->
	<application
		android:name="app.core.AIOApp"
		android:enableOnBackInvokedCallback="true"
		android:extractNativeLibs="true"
		android:hardwareAccelerated="true"
		android:icon="@mipmap/ic_launcher_v2"
		android:label="@string/title_app_name"
		android:largeHeap="true"
		android:requestLegacyExternalStorage="true"
		android:roundIcon="@mipmap/ic_launcher_v2"
		android:supportsRtl="false"
		android:theme="@style/style.application"
		android:usesCleartextTraffic="true"
		tools:targetApi="33">
		
		<!--
			LAUNCHER ACTIVITY: Main entry point of the application
			Exported=true allows other apps to launch this activity
		-->
		<activity
			android:name="app.ui.others.startup.LauncherActivity"
			android:exported="true">
			<intent-filter>
				<action android:name="android.intent.action.MAIN" />
				<category android:name="android.intent.category.LAUNCHER" />
			</intent-filter>
		</activity>
		
		<!--
			OPENING ACTIVITY: Initial splash/loading screen
			No history means it won't appear in back stack
			Exclude from recents prevents showing in recent apps list
		-->
		<activity
			android:name="app.ui.others.startup.OpeningActivity"
			android:excludeFromRecents="true"
			android:launchMode="singleTop"
			android:noHistory="true"
			android:resizeableActivity="true"
			android:taskAffinity=""
			android:windowSoftInputMode="adjustResize" />
		
		<!--
			INTENT INTERCEPT ACTIVITY: Handles shared text/content from other apps
			Transparent theme makes sharing seamless
			Handles ACTION_SEND intent for text sharing
		-->
		<activity
			android:name="app.ui.others.information.IntentInterceptActivity"
			android:clearTaskOnLaunch="true"
			android:excludeFromRecents="true"
			android:exported="true"
			android:label="@string/text_empty_string"
			android:launchMode="singleTop"
			android:noHistory="true"
			android:resizeableActivity="true"
			android:taskAffinity=""
			android:theme="@style/style.transparent_activity"
			android:windowSoftInputMode="adjustResize">
			<intent-filter>
				<action android:name="android.intent.action.SEND" />
				<category android:name="android.intent.category.DEFAULT" />
				<data android:mimeType="text/plain" />
			</intent-filter>
		</activity>
		
		<!--
			MEDIA PLAYER ACTIVITY: Video/audio playback screen
			Supports Picture-in-Picture (PiP) mode for Android 8+
			Config changes prevent activity restart on configuration changes
		-->
		<activity
			android:name="app.ui.others.media_player.MediaPlayerActivity"
			android:configChanges="orientation|screenSize|layoutDirection|
			screenLayout|smallestScreenSize|keyboardHidden|uiMode"
			android:exported="false"
			android:label="@string/title_aio_video_player"
			android:launchMode="singleTop"
			android:resizeableActivity="true"
			android:supportsPictureInPicture="true"
			android:theme="@style/style.application.video_player_activity"
			android:windowSoftInputMode="adjustResize" />
		
		<!--
			MOTHER ACTIVITY: Main container activity for fragments
			SingleTop launch mode prevents multiple instances
			Task affinity creates separate task stack
		-->
		<activity
			android:name="app.ui.main.MotherActivity"
			android:alwaysRetainTaskState="true"
			android:excludeFromRecents="false"
			android:exported="false"
			android:hardwareAccelerated="true"
			android:launchMode="singleTop"
			android:taskAffinity="com.aio.mother"
			android:theme="@style/style.application"
			android:windowSoftInputMode="adjustPan" />
		
		<!--
			SETTINGS ACTIVITIES: Various settings and configuration screens
			All are internal activities (exported=false) for security
		-->
		<activity
			android:name="app.ui.main.fragments.settings.activities.browser.AdvBrowserSettingsActivity"
			android:exported="false"
			android:launchMode="singleTop"
			android:windowSoftInputMode="adjustPan" />
		
		<activity
			android:name="app.ui.others.information.UserFeedbackActivity"
			android:exported="false"
			android:launchMode="singleTop"
			android:windowSoftInputMode="adjustPan" />
		
		<activity
			android:name="app.ui.main.fragments.browser.activities.BookmarksActivity"
			android:exported="false"
			android:launchMode="singleTop"
			android:windowSoftInputMode="adjustPan" />
		
		<activity
			android:name="app.ui.main.fragments.browser.activities.HistoryActivity"
			android:exported="false"
			android:launchMode="singleTop"
			android:windowSoftInputMode="adjustPan" />
		
		<activity
			android:name="app.ui.others.startup.EmptyLayoutActivity"
			android:exported="false"
			android:launchMode="singleTop"
			android:windowSoftInputMode="adjustPan" />
		
		<activity
			android:name="app.core.bases.language.LanguagePrepareActivity"
			android:exported="false"
			android:launchMode="singleTop"
			android:windowSoftInputMode="adjustPan" />
		
		<!--
			FOREGROUND SERVICE: Long-running background service for downloads
			Foreground service type must match permission declaration
			Exported=false prevents external access
		-->
		<service
			android:name="app.core.engines.services.AIOForegroundService"
			android:enabled="true"
			android:exported="false"
			android:foregroundServiceType="dataSync" />
		
		<!--
			BROADCAST RECEIVER: Restarts services after device reboot
			Listens for BOOT_COMPLETED broadcast
			Exported=false as it's for internal use only
		-->
		<receiver
			android:name="app.core.engines.services.RestartIdleServiceReceiver"
			android:enabled="true"
			android:exported="false" />
		
		<!--
			FILE PROVIDER: Secure file sharing between app components
			Uses AndroidX FileProvider for secure file URI sharing
			Grants temporary permissions for file access
		-->
		<provider
			android:name="androidx.core.content.FileProvider"
			android:authorities="${applicationId}.provider"
			android:exported="false"
			android:grantUriPermissions="true">
			<meta-data
				android:name="android.support.FILE_PROVIDER_PATHS"
				android:resource="@xml/file_paths" />
		</provider>
		
		<!--
			PARSE SERVER CONFIGURATION: Back4App backend service integration
			Contains server URL, application ID, and client key
			Used for cloud backup and data synchronization
		-->
		<meta-data
			android:name="com.parse.SERVER_URL"
			android:value="@string/text_back4app_server_url" />
		
		<meta-data
			android:name="com.parse.APPLICATION_ID"
			android:value="@string/text_back4app_app_id" />
		
		<meta-data
			android:name="com.parse.CLIENT_KEY"
			android:value="@string/text_back4app_client_key" />
	
	</application>
	
	<!--
		====================================================================
		PACKAGE QUERIES (Android 11+)
		====================================================================
		
		Declares which other apps this app needs to interact with.
		Required for Android 11+ package visibility restrictions.
	-->
	<queries>
		<!-- Email intent query for sharing functionality -->
		<intent>
			<action android:name="android.intent.action.SEND" />
			<data android:mimeType="message/rfc822" />
		</intent>
		
		<!-- Web browser intent query for URL handling -->
		<intent>
			<action android:name="android.intent.action.VIEW" />
			<category android:name="android.intent.category.BROWSABLE" />
			<data android:scheme="https" />
		</intent>
		
		<!--
			SOCIAL MEDIA AND CONTENT APPS:
			Apps that this downloader can interact with for content extraction
			These are common sources for video/audio downloads
		-->
		<package android:name="com.google.android.youtube" />
		<package android:name="com.instagram.android" />
		<package android:name="com.facebook.katana" />
		<package android:name="com.whatsapp" />
		<package android:name="com.ted.android" />
		<package android:name="com.google.android.apps.youtube.music" />
		<package android:name="com.soundcloud.android" />
		<package android:name="com.pinterest" />
		<package android:name="com.zhiliaoapp.musically" />
		<package android:name="com.dailymotion.dailymotion" />
		<package android:name="com.reddit.frontpage" />
		<package android:name="com.twitter.android" />
	</queries>
</manifest>