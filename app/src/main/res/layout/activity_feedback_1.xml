<?xml version="1.0" encoding="utf-8"?><!-- Main container for user feedback screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@drawable/ic_background_gradient"
	android:orientation="vertical"
	tools:context="app.ui.others.information.UserFeedbackActivityVideo"
	tools:ignore="UseCompatTextViewDrawableXml,UseAppTint"
	>
	
	<androidx.cardview.widget.CardView
		android:id="@+id/top_actionbar_section"
		android:layout_width="match_parent"
		android:layout_height="@dimen/_50"
		android:layout_marginStart="@dimen/_10"
		android:layout_marginTop="@dimen/_10"
		android:layout_marginEnd="@dimen/_10"
		android:layout_marginBottom="@dimen/_5"
		app:cardBackgroundColor="@color/color_actionbar_title_bg"
		app:cardCornerRadius="@dimen/_10"
		>
		
		<RelativeLayout
			android:id="@+id/container_actionbar_top"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			>
			
			<RelativeLayout
				android:id="@+id/btn_left_actionbar"
				android:layout_width="@dimen/_50"
				android:layout_height="match_parent"
				android:background="@drawable/ic_button_negative_selector"
				android:clickable="true"
				tools:ignore="SpeakableTextPresentCheck"
				>
				
				<ImageView
					android:id="@+id/btn_left_actionbar_img"
					android:layout_width="@dimen/_30"
					android:layout_height="wrap_content"
					android:layout_centerInParent="true"
					android:adjustViewBounds="true"
					android:importantForAccessibility="no"
					android:src="@drawable/ic_button_actionbar_back"
					android:tint="@color/color_secondary"
					tools:ignore="ImageContrastCheck"
					/>
			</RelativeLayout>
			
			<TextView
				android:id="@+id/txt_actionbar"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_0"
				android:layout_marginEnd="@dimen/_10"
				android:layout_marginBottom="@dimen/_0"
				android:layout_toStartOf="@id/btn_right_actionbar"
				android:layout_toEndOf="@id/btn_left_actionbar"
				android:ellipsize="end"
				android:fontFamily="@font/application_font_family"
				android:gravity="center_vertical"
				android:maxLines="1"
				android:text="@string/title_share_feedback"
				android:textFontWeight="600"
				android:textSize="@dimen/title_text_size"
				/>
			
			<RelativeLayout
				android:id="@+id/btn_right_actionbar"
				android:layout_width="@dimen/_50"
				android:layout_height="match_parent"
				android:layout_alignParentEnd="true"
				android:background="@drawable/ic_button_negative_selector"
				android:clickable="true"
				tools:ignore="SpeakableTextPresentCheck"
				>
				
				<ImageView
					android:id="@+id/btn_right_actionbar_img"
					android:layout_width="@dimen/_30"
					android:layout_height="wrap_content"
					android:layout_centerInParent="true"
					android:adjustViewBounds="true"
					android:importantForAccessibility="no"
					android:src="@drawable/ic_button_actionbar_send"
					android:tint="@color/color_secondary"
					tools:ignore="ImageContrastCheck"
					/>
			</RelativeLayout>
		</RelativeLayout>
	</androidx.cardview.widget.CardView>
	
	<ScrollView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		>
		
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			>
			
			<androidx.cardview.widget.CardView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_10"
				android:layout_marginBottom="@dimen/_10"
				android:orientation="vertical"
				app:cardBackgroundColor="@color/color_cardview_bg"
				app:cardCornerRadius="@dimen/_10"
				>
				
				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_10"
					android:layout_marginTop="@dimen/_10"
					android:layout_marginEnd="@dimen/_10"
					android:layout_marginBottom="@dimen/_10"
					android:orientation="vertical"
					>
					
					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:autoLink="web"
						android:fontFamily="@font/application_font_family"
						android:gravity="center"
						android:text="@string/text_feedback_message"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/message_text_size"
						/>
				</LinearLayout>
			</androidx.cardview.widget.CardView>
			
			<androidx.cardview.widget.CardView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_0"
				android:layout_marginEnd="@dimen/_10"
				android:layout_marginBottom="@dimen/_10"
				android:orientation="vertical"
				app:cardBackgroundColor="@color/color_cardview_bg"
				app:cardCornerRadius="@dimen/_10"
				>
				
				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_10"
					android:layout_marginTop="@dimen/_10"
					android:layout_marginEnd="@dimen/_10"
					android:layout_marginBottom="@dimen/_10"
					android:orientation="vertical"
					>
					
					<CheckBox
						android:id="@+id/checkbox_no_sound"
						android:layout_width="match_parent"
						android:layout_height="@dimen/_36"
						android:background="@drawable/ic_button_negative_selector"
						android:button="@null"
						android:clickable="true"
						android:drawableStart="@drawable/ic_button_radio_selector"
						android:drawablePadding="@dimen/_10"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:gravity="center_vertical"
						android:maxLines="1"
						android:text="@string/title_no_sound"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size"
						tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize"
						/>
					
					<CheckBox
						android:id="@+id/checkbox_incomplete_video"
						android:layout_width="match_parent"
						android:layout_height="@dimen/_36"
						android:background="@drawable/ic_button_negative_selector"
						android:button="@null"
						android:clickable="true"
						android:drawableStart="@drawable/ic_button_radio_selector"
						android:drawablePadding="@dimen/_10"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:gravity="center_vertical"
						android:maxLines="1"
						android:text="@string/title_incomplete_video"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size"
						tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize"
						/>
					
					<CheckBox
						android:id="@+id/checkbox_app_crashed"
						android:layout_width="match_parent"
						android:layout_height="@dimen/_36"
						android:background="@drawable/ic_button_negative_selector"
						android:button="@null"
						android:clickable="true"
						android:drawableStart="@drawable/ic_button_radio_selector"
						android:drawablePadding="@dimen/_10"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:gravity="center_vertical"
						android:maxLines="1"
						android:text="@string/title_app_crashed"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size"
						tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize"
						/>
					
					<CheckBox
						android:id="@+id/checkbox_glitch_in_video"
						android:layout_width="match_parent"
						android:layout_height="@dimen/_36"
						android:background="@drawable/ic_button_negative_selector"
						android:button="@null"
						android:clickable="true"
						android:drawableStart="@drawable/ic_button_radio_selector"
						android:drawablePadding="@dimen/_10"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:gravity="center_vertical"
						android:maxLines="1"
						android:text="@string/title_glitch_in_video"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size"
						tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize"
						/>
					
					<CheckBox
						android:id="@+id/checkbox_showing_too_many_ads"
						android:layout_width="match_parent"
						android:layout_height="@dimen/_36"
						android:background="@drawable/ic_button_negative_selector"
						android:button="@null"
						android:clickable="true"
						android:drawableStart="@drawable/ic_button_radio_selector"
						android:drawablePadding="@dimen/_10"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:gravity="center_vertical"
						android:maxLines="1"
						android:text="@string/title_showing_many_ads"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size"
						tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize"
						/>
					
					<CheckBox
						android:id="@+id/checkbox_other_problem"
						android:layout_width="match_parent"
						android:layout_height="@dimen/_36"
						android:background="@drawable/ic_button_negative_selector"
						android:button="@null"
						android:clickable="true"
						android:drawableStart="@drawable/ic_button_radio_selector"
						android:drawablePadding="@dimen/_10"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:gravity="center_vertical"
						android:maxLines="1"
						android:text="@string/title_other_problems"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size"
						tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize"
						/>
				</LinearLayout>
			</androidx.cardview.widget.CardView>
			
			<androidx.cardview.widget.CardView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_0"
				android:layout_marginEnd="@dimen/_10"
				android:layout_marginBottom="@dimen/_10"
				android:orientation="vertical"
				app:cardBackgroundColor="@color/color_cardview_bg"
				app:cardCornerRadius="@dimen/_10"
				>
				
				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_5"
					android:orientation="vertical"
					>
					
					<LinearLayout
						android:id="@+id/container_edit_email_field"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_3"
						android:layout_marginEnd="@dimen/_5"
						android:layout_marginBottom="@dimen/_8"
						android:background="@drawable/rounded_surface_color"
						android:orientation="vertical"
						>
						
						<EditText
							android:id="@+id/edit_email_field"
							style="@style/style_dialog.message"
							android:layout_margin="@dimen/_8"
							android:background="@color/transparent"
							android:drawableLeft="@drawable/ic_button_email_address"
							android:drawablePadding="@dimen/_8"
							android:drawableTint="@color/color_secondary"
							android:gravity="center_vertical"
							android:hint="@string/title_enter_your_email_address_here"
							android:importantForAutofill="no"
							android:inputType="textEmailAddress"
							android:maxLines="1"
							android:singleLine="true"
							android:textColor="@color/color_on_surface"
							android:textColorHint="@color/color_text_hint"
							android:textSize="@dimen/normal_text_size"
							android:textStyle="normal"
							tools:ignore="TextContrastCheck,TouchTargetSizeCheck,VisualLintTextFieldSize"
							/>
					</LinearLayout>
					
					<LinearLayout
						android:id="@+id/container_edit_message_field"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_5"
						android:layout_marginBottom="@dimen/_3"
						android:background="@drawable/rounded_surface_color"
						android:orientation="vertical"
						>
						
						<EditText
							android:id="@+id/edit_message_field"
							style="@style/style_dialog.message"
							android:layout_margin="@dimen/_8"
							android:background="@color/transparent"
							android:drawableLeft="@drawable/ic_button_edit_text"
							android:drawablePadding="@dimen/_8"
							android:drawableTint="@color/color_secondary"
							android:gravity="start"
							android:hint="@string/title_describe_your_experience"
							android:importantForAutofill="no"
							android:inputType="text"
							android:singleLine="true"
							android:textColor="@color/color_on_surface"
							android:textColorHint="@color/color_text_hint"
							android:textSize="@dimen/normal_text_size"
							android:textStyle="normal"
							tools:ignore="TextContrastCheck,VisualLintTextFieldSize,TouchTargetSizeCheck"
							/>
					</LinearLayout>
				</LinearLayout>
			</androidx.cardview.widget.CardView>
		</LinearLayout>
	</ScrollView>
</LinearLayout>