<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/style_dialog"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	tools:ignore="UseAppTint,UseCompatTextViewDrawableXml">

	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginStart="@dimen/_5"
		android:layout_marginTop="@dimen/_10"
		android:layout_marginEnd="@dimen/_5"
		android:layout_marginBottom="@dimen/_10"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_5">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="@color/color_cardview_title_bg"
				android:orientation="vertical">

				<TextView
					android:id="@+id/txt_dialog_title"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_margin="@dimen/_10"
					android:ellipsize="end"
					android:fontFamily="@font/font_family_bold"
					android:gravity="center"
					android:maxLines="1"
					android:text="@string/title_no_videos_found"
					android:textColor="@color/color_text_primary"
					android:textSize="@dimen/normal_text_size" />
			</LinearLayout>

			<com.airbnb.lottie.LottieAnimationView
				android:id="@+id/img_no_video_found"
				android:layout_width="@dimen/_150"
				android:layout_height="wrap_content"
				android:layout_gravity="center"
				android:layout_marginTop="@dimen/_5"
				android:adjustViewBounds="true"
				android:hardwareAccelerated="true"
				android:importantForAccessibility="no"
				android:layerType="hardware"
				android:minHeight="@dimen/_50"
				app:lottie_autoPlay="true"
				app:lottie_enableMergePathsForKitKatAndAbove="true"
				app:lottie_loop="true"
				tools:ignore="ImageContrastCheck" />

			<TextView
				android:id="@+id/txt_info"
				style="@style/style_dialog.message"
				android:layout_gravity="center_vertical|center_horizontal"
				android:layout_marginStart="@dimen/_20"
				android:layout_marginTop="@dimen/_10"
				android:layout_marginEnd="@dimen/_20"
				android:layout_marginBottom="@dimen/_0"
				android:autoLink="web"
				android:fontFamily="@font/font_family_regular"
				android:text="@string/text_no_video_resources_found"
				android:textSize="@dimen/message_text_size" />

			<RelativeLayout
				android:id="@+id/btn_dialog_positive_container"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_8"
				android:layout_marginEnd="@dimen/_10"
				android:layout_marginBottom="@dimen/_8"
				android:background="@drawable/ic_button_selector_secondary"
				android:clickable="true"
				android:elevation="@dimen/_2"
				tools:ignore="TouchTargetSizeCheck">

				<TextView
					android:id="@+id/btn_dialog_positive"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_centerInParent="true"
					android:layout_margin="@dimen/_7"
					android:drawableStart="@drawable/ic_button_question"
					android:drawablePadding="@dimen/_5"
					android:drawableTint="@color/color_on_secondary"
					android:fontFamily="@font/font_family_semibold"
					android:gravity="center"
					android:text="@string/title_how_to_download"
					android:textColor="@color/color_on_secondary"
					android:textSize="@dimen/normal_text_size" />
			</RelativeLayout>

		</LinearLayout>
	</androidx.cardview.widget.CardView>
</LinearLayout>