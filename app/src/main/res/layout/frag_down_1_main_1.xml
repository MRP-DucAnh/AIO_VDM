<?xml version="1.0" encoding="utf-8"?>
<!-- =========================================================================
     Downloads Manager Fragment Layout
     Main container for downloads management with action bar, sorting controls,
     view pager for tab navigation, and storage information display.
     Includes card-based design with consistent spacing and visual hierarchy.
     ========================================================================= -->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/transparent"
	android:orientation="vertical"
	tools:ignore="UseCompatTextViewDrawableXml,UseAppTint">

	<!-- ==================================================
		 TOP ACTION BAR SECTION
		 Card-based action bar with navigation controls,
		 title display, and action buttons (search, add, menu).
		 Provides primary user interactions for downloads management.
		 ================================================== -->
	<androidx.cardview.widget.CardView
		android:id="@+id/top_actionbar_section"
		android:layout_width="match_parent"
		android:layout_height="@dimen/_50"
		android:layout_marginStart="@dimen/_10"
		android:layout_marginTop="@dimen/_10"
		android:layout_marginEnd="@dimen/_10"
		android:layout_marginBottom="@dimen/_5"
		app:cardBackgroundColor="@color/color_actionbar_title_bg"
		app:cardCornerRadius="@dimen/_10">

		<RelativeLayout
			android:id="@+id/container_actionbar_top"
			android:layout_width="match_parent"
			android:layout_height="match_parent">

			<!-- Back navigation button for returning to previous screen -->
			<RelativeLayout
				android:id="@+id/btn_actionbar_back"
				android:layout_width="@dimen/_50"
				android:layout_height="match_parent"
				android:background="@drawable/ic_button_negative_selector"
				android:clickable="true"
				tools:ignore="SpeakableTextPresentCheck">

				<ImageView
					android:id="@+id/btn_left_actionbar_img"
					android:layout_width="@dimen/_30"
					android:layout_height="wrap_content"
					android:layout_centerInParent="true"
					android:adjustViewBounds="true"
					android:importantForAccessibility="no"
					android:src="@drawable/ic_button_actionbar_back"
					android:tint="@color/color_secondary"
					tools:ignore="ImageContrastCheck" />
			</RelativeLayout>

			<!-- Current fragment title display centered in action bar -->
			<TextView
				android:id="@+id/txt_current_frag_name"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_0"
				android:layout_marginEnd="@dimen/_10"
				android:layout_marginBottom="@dimen/_0"
				android:layout_toStartOf="@id/btn_actionbar_search"
				android:layout_toEndOf="@id/btn_actionbar_back"
				android:ellipsize="end"
				android:fontFamily="@font/application_font_family"
				android:gravity="center_vertical"
				android:maxLines="1"
				android:text="@string/title_downloads_manager"
				android:textFontWeight="600"
				android:textSize="@dimen/title_text_size" />

			<!-- Search action button (initially hidden, shown when needed) -->
			<RelativeLayout
				android:id="@+id/btn_actionbar_search"
				android:layout_width="@dimen/_50"
				android:layout_height="match_parent"
				android:layout_toStartOf="@+id/btn_actionbar_add_download"
				android:background="@drawable/ic_button_negative_selector"
				android:clickable="true"
				android:visibility="gone"
				tools:ignore="SpeakableTextPresentCheck">

				<ImageView
					android:id="@+id/btn_middle_actionbar_img"
					android:layout_width="@dimen/_30"
					android:layout_height="wrap_content"
					android:layout_centerInParent="true"
					android:adjustViewBounds="true"
					android:importantForAccessibility="no"
					android:src="@drawable/ic_button_actionbar_search"
					android:tint="@color/color_secondary"
					tools:ignore="ImageContrastCheck" />
			</RelativeLayout>

			<!-- Add new download action button -->
			<RelativeLayout
				android:id="@+id/btn_actionbar_add_download"
				android:layout_width="@dimen/_50"
				android:layout_height="match_parent"
				android:layout_toStartOf="@+id/btn_actionbar_options"
				android:background="@drawable/ic_button_negative_selector"
				android:clickable="true"
				tools:ignore="SpeakableTextPresentCheck">

				<ImageView
					android:id="@+id/btn_right_actionbar_img"
					android:layout_width="@dimen/_30"
					android:layout_height="wrap_content"
					android:layout_centerInParent="true"
					android:adjustViewBounds="true"
					android:importantForAccessibility="no"
					android:src="@drawable/ic_button_actionbar_plus"
					android:tint="@color/color_secondary"
					tools:ignore="ImageContrastCheck" />
			</RelativeLayout>

			<!-- Options menu action button for additional settings -->
			<RelativeLayout
				android:id="@+id/btn_actionbar_options"
				android:layout_width="@dimen/_50"
				android:layout_height="match_parent"
				android:layout_alignParentEnd="true"
				android:background="@drawable/ic_button_negative_selector"
				android:clickable="true"
				tools:ignore="SpeakableTextPresentCheck">

				<ImageView
					android:id="@+id/btn_right_most_actionbar_img"
					android:layout_width="@dimen/_30"
					android:layout_height="wrap_content"
					android:layout_centerInParent="true"
					android:adjustViewBounds="true"
					android:importantForAccessibility="no"
					android:src="@drawable/ic_button_actionbar_menu"
					android:tint="@color/color_secondary"
					tools:ignore="ImageContrastCheck" />
			</RelativeLayout>

		</RelativeLayout>
	</androidx.cardview.widget.CardView>

	<!-- ==================================================
		 SORTING AND PRIVATE FILES CONTROL SECTION
		 Card container with two main actions: sort list and toggle
		 private files visibility. Includes counter for private files.
		 ================================================== -->
	<androidx.cardview.widget.CardView
		android:id="@+id/container_top_sorts_private"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginStart="@dimen/_10"
		android:layout_marginTop="@dimen/_5"
		android:layout_marginEnd="@dimen/_10"
		android:layout_marginBottom="@dimen/_6"
		android:orientation="vertical"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:layout_marginStart="@dimen/_8"
			android:layout_marginTop="@dimen/_3"
			android:layout_marginEnd="@dimen/_8"
			android:layout_marginBottom="@dimen/_3"
			android:baselineAligned="false"
			android:orientation="horizontal">

			<!-- Sort list button for organizing downloads by various criteria -->
			<RelativeLayout
				android:id="@+id/btn_sort_the_list"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_gravity="center_vertical"
				android:layout_margin="@dimen/_0"
				android:layout_weight="1"
				android:background="@drawable/ic_button_negative_selector"
				android:clickable="true"
				tools:ignore="TouchTargetSizeCheck">

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_centerInParent="true"
					android:layout_margin="@dimen/_8"
					android:drawableStart="@drawable/ic_button_sort"
					android:drawablePadding="@dimen/_5"
					android:drawableTint="@color/color_secondary"
					android:fontFamily="@font/application_font_family"
					android:gravity="center_vertical"
					android:text="@string/title_sort_list_by"
					android:textFontWeight="500"
					android:textSize="@dimen/normal_text_size" />
			</RelativeLayout>

			<!-- Visual separator between the two action buttons -->
			<View
				android:layout_width="@dimen/_2"
				android:layout_height="match_parent"
				android:layout_marginHorizontal="@dimen/_5"
				android:layout_marginVertical="@dimen/_2"
				android:alpha=".5"
				android:background="@drawable/rounded_border_color" />

			<!-- Toggle private files visibility with counter display -->
			<RelativeLayout
				android:id="@+id/btn_toggle_private_files"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_gravity="center_vertical"
				android:layout_margin="@dimen/_0"
				android:layout_weight="1"
				android:background="@drawable/ic_button_negative_selector"
				android:clickable="true"
				tools:ignore="TouchTargetSizeCheck">

				<TextView
					android:id="@+id/txt_private_toggle"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_centerInParent="true"
					android:layout_margin="@dimen/_8"
					android:drawableStart="@drawable/ic_button_unlock_v1"
					android:drawablePadding="@dimen/_5"
					android:drawableTint="@color/color_secondary"
					android:fontFamily="@font/application_font_family"
					android:gravity="center_vertical"
					android:text="@string/title_toggle_private_files"
					android:textFontWeight="500"
					android:textSize="@dimen/normal_text_size" />

				<!-- Counter badge showing number of private files -->
				<TextView
					android:id="@+id/txt_private_file_counter"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_alignParentEnd="true"
					android:layout_marginHorizontal="@dimen/_5"
					android:layout_marginTop="@dimen/_1"
					android:background="@drawable/rounded_secondary_color"
					android:paddingStart="@dimen/_3"
					android:paddingTop="@dimen/_1"
					android:gravity="center"
					android:paddingEnd="@dimen/_3"
					android:paddingBottom="@dimen/_1"
					android:text="@string/text_empty_string"
					android:textColor="@color/color_on_secondary"
					android:textFontWeight="500"
					android:textSize="@dimen/smallest_text_size"
					android:visibility="gone" />
			</RelativeLayout>
		</LinearLayout>
	</androidx.cardview.widget.CardView>

	<!-- ==================================================
		 MAIN CONTENT AREA WITH BOTTOM STORAGE INFO
		 ConstraintLayout managing fragment content area and
		 fixed bottom storage information display.
		 ================================================== -->
	<androidx.constraintlayout.widget.ConstraintLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent">

		<!-- Fragment content area hosting view pager for tab navigation -->
		<RelativeLayout
			android:id="@+id/container_fragment_area"
			android:layout_width="0dp"
			android:layout_height="0dp"
			android:layout_marginBottom="@dimen/_5"
			android:background="@color/transparent"
			app:layout_constraintBottom_toTopOf="@id/container_bottom_storage_info"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toTopOf="parent">

			<!-- Non-swappable view pager for hosting download fragments -->
			<lib.ui.builders.NonSwappableViewPager
				android:id="@+id/fragment_viewpager"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				tools:ignore="SpeakableTextPresentCheck" />

		</RelativeLayout>

		<!-- Fixed bottom card showing device storage information -->
		<androidx.cardview.widget.CardView
			android:id="@+id/container_bottom_storage_info"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/_20"
			android:layout_marginTop="@dimen/_5"
			android:layout_marginEnd="@dimen/_20"
			android:layout_marginBottom="@dimen/_3"
			android:orientation="vertical"
			app:cardBackgroundColor="@color/color_cardview_bg"
			app:cardCornerRadius="@dimen/_10"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:layout_marginStart="@dimen/_8"
				android:layout_marginTop="@dimen/_3"
				android:layout_marginEnd="@dimen/_8"
				android:layout_marginBottom="@dimen/_3"
				android:baselineAligned="false"
				android:orientation="horizontal"
				tools:ignore="UseCompoundDrawables">

				<!-- SD card icon indicating storage information -->
				<ImageView
					android:layout_width="@dimen/_20"
					android:layout_height="@dimen/_20"
					android:layout_gravity="center_vertical"
					android:adjustViewBounds="true"
					android:importantForAccessibility="no"
					android:src="@drawable/ic_button_sd_card"
					android:tint="@color/color_secondary" />

				<!-- Storage information text showing available space -->
				<TextView
					android:id="@+id/txt_device_storage_info"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_gravity="center_vertical"
					android:layout_marginHorizontal="@dimen/_5"
					android:text="@string/title_sample_storage_info"
					android:textFontWeight="500"
					android:textSize="@dimen/small_text_size" />

			</LinearLayout>
		</androidx.cardview.widget.CardView>
	</androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>