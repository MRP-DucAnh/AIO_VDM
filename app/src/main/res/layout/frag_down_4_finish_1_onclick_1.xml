<?xml version="1.0" encoding="utf-8"?>
<!--
    COMPLETED DOWNLOAD FILE OPTIONS DIALOG
    This layout provides a comprehensive action menu for downloaded files with
    thumbnail preview and multiple action categories. Features media playback,
    file management, sharing options, and advanced file operations in a
    structured card-based dialog interface.
    =========================================================================== -->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/style_dialog"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	tools:ignore="UseAppTint,UseCompatTextViewDrawableXml">

	<!--
		MAIN DIALOG CARD CONTAINER
		Provides elevated card appearance with rounded corners and shadow effects.
		Uses consistent margin spacing and background coloring for visual consistency
		across the application's dialog system.
		========================================================================= -->
	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginStart="@dimen/_5"
		android:layout_marginTop="@dimen/_10"
		android:layout_marginEnd="@dimen/_5"
		android:layout_marginBottom="@dimen/_10"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_5">

		<!--
			DIALOG CONTENT CONTAINER
			Vertical layout organizing all dialog elements in logical sections:
			file preview, action button rows, and advanced operations.
			Maintains consistent spacing and visual hierarchy.
			============================================================ -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<!--
				FILE INFORMATION CARD
				Interactive card displaying file thumbnail, title, URL, and quick actions.
				Uses RelativeLayout for flexible positioning of thumbnail and text elements
				with touch feedback for user interaction.
				============================================================ -->
			<RelativeLayout
				android:id="@+id/btn_file_info_card"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginStart="@dimen/_8"
				android:layout_marginTop="@dimen/_8"
				android:layout_marginEnd="@dimen/_8"
				android:layout_marginBottom="@dimen/_8"
				android:background="@drawable/ic_button_cardview_selector"
				android:clickable="true"
				android:elevation="@dimen/_2"
				tools:ignore="DuplicateSpeakableTextCheck">

				<!--
					THUMBNAIL CONTAINER WITH OVERLAY INDICATORS
					Card-based thumbnail display with multiple visual indicators:
					play button, site favicon, file type, privacy status, and duration.
					Uses layered ImageView elements for comprehensive file metadata display.
					============================================================ -->
				<androidx.cardview.widget.CardView
					android:id="@+id/thumbnail_container"
					android:layout_width="@dimen/_85"
					android:layout_height="@dimen/_55"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_0"
					android:layout_marginBottom="@dimen/_5"
					android:background="@color/transparent"
					app:cardCornerRadius="@dimen/_5">

					<!-- Play indicator overlay for media files -->
					<ImageView
						android:id="@+id/img_media_play_indicator"
						android:layout_width="@dimen/_20"
						android:layout_height="wrap_content"
						android:layout_gravity="center"
						android:adjustViewBounds="true"
						android:elevation="@dimen/_5"
						android:importantForAccessibility="no"
						android:src="@drawable/image_media_play"
						android:tint="@color/color_on_primary"
						android:visibility="visible"
						tools:ignore="ImageContrastCheck" />

					<!-- Main file thumbnail with fallback image -->
					<ImageView
						android:id="@+id/img_file_thumbnail"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_centerVertical="true"
						android:adjustViewBounds="true"
						android:importantForAccessibility="no"
						android:scaleType="centerCrop"
						android:src="@drawable/image_no_thumb_available"
						tools:ignore="ImageContrastCheck" />

					<!-- Source website favicon indicator -->
					<ImageView
						android:id="@+id/img_site_favicon"
						android:layout_width="@dimen/_15"
						android:layout_height="wrap_content"
						android:layout_gravity="start|top"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_5"
						android:adjustViewBounds="true"
						android:elevation="@dimen/_5"
						android:importantForAccessibility="no"
						android:src="@drawable/ic_image_default_favicon"
						android:visibility="visible"
						tools:ignore="ImageContrastCheck" />

					<!-- File type icon indicator (video, audio, document) -->
					<ImageView
						android:id="@+id/img_file_type_indicator"
						android:layout_width="@dimen/_17"
						android:layout_height="wrap_content"
						android:layout_gravity="start|bottom"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_5"
						android:layout_marginBottom="@dimen/_5"
						android:adjustViewBounds="true"
						android:background="@drawable/rounded_transparent_black"
						android:elevation="@dimen/_2"
						android:importantForAccessibility="no"
						android:src="@drawable/ic_button_video"
						android:tint="@color/color_on_primary"
						android:visibility="visible"
						tools:ignore="ImageContrastCheck" />

					<!-- Private folder storage indicator -->
					<ImageView
						android:id="@+id/img_private_folder_indicator"
						android:layout_width="@dimen/_17"
						android:layout_height="wrap_content"
						android:layout_gravity="end|bottom"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_5"
						android:layout_marginEnd="@dimen/_5"
						android:layout_marginBottom="@dimen/_5"
						android:adjustViewBounds="true"
						android:background="@drawable/rounded_transparent_black"
						android:elevation="@dimen/_2"
						android:importantForAccessibility="no"
						android:src="@drawable/ic_button_folder"
						android:tint="@color/color_on_primary"
						android:visibility="visible"
						tools:ignore="ImageContrastCheck" />

					<!-- Media duration display in rounded badge -->
					<LinearLayout
						android:id="@+id/container_media_duration"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_gravity="end"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_5"
						android:layout_marginEnd="@dimen/_5"
						android:layout_marginBottom="@dimen/_5"
						android:background="@drawable/rounded_primary_color"
						android:orientation="vertical"
						android:visibility="visible">

						<!-- Formatted duration text (HH:MM:SS) -->
						<TextView
							android:id="@+id/txt_media_duration"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginStart="@dimen/_5"
							android:layout_marginTop="@dimen/_1"
							android:layout_marginEnd="@dimen/_5"
							android:layout_marginBottom="@dimen/_1"
							android:fontFamily="@font/application_font_family"
							android:text="@string/title_time_representation"
							android:textColor="@color/color_on_primary"
							android:textSize="@dimen/smaller_text_size"
							android:textStyle="normal"
							tools:ignore="TextContrastCheck" />
					</LinearLayout>
				</androidx.cardview.widget.CardView>

				<!--
					FILE METADATA CONTAINER
					Displays file title and source URL with marquee scrolling for
					long text. Includes quick play button for immediate media playback.
					============================================================ -->
				<RelativeLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_centerVertical="true"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginEnd="@dimen/_5"
					android:layout_toEndOf="@+id/thumbnail_container"
					android:orientation="vertical">

					<!-- File title with marquee scrolling capability -->
					<TextView
						android:id="@+id/txt_file_title"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginBottom="@dimen/_3"
						android:layout_toStartOf="@+id/img_open_file"
						android:ellipsize="marquee"
						android:focusable="true"
						android:focusableInTouchMode="true"
						android:fontFamily="@font/application_font_family"
						android:marqueeRepeatLimit="marquee_forever"
						android:scrollHorizontally="true"
						android:singleLine="true"
						android:text="@string/title__"
						android:textColor="@color/color_on_primary"
						android:textSize="@dimen/normal_text_size"
						android:textStyle="bold" />

					<!-- Source URL display with semi-transparent background -->
					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_below="@id/txt_file_title"
						android:layout_toStartOf="@id/img_open_file"
						android:alpha="0.5"
						android:background="@drawable/rounded_transparent_white_f5"
						android:orientation="vertical">

						<TextView
							android:id="@+id/txt_file_url"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginStart="@dimen/_5"
							android:layout_marginTop="@dimen/_2"
							android:layout_marginEnd="@dimen/_5"
							android:layout_marginBottom="@dimen/_2"
							android:alpha="1"
							android:ellipsize="end"
							android:fontFamily="@font/application_font_family"
							android:singleLine="true"
							android:text="@string/title__"
							android:textColor="@color/color_on_primary"
							android:textSize="@dimen/small_text_size"
							tools:ignore="TextContrastCheck" />
					</LinearLayout>

					<!-- Quick play button for media files -->
					<ImageView
						android:id="@+id/img_open_file"
						android:layout_width="@dimen/_30"
						android:layout_height="@dimen/_30"
						android:layout_alignParentEnd="true"
						android:layout_centerVertical="true"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginEnd="@dimen/_5"
						android:adjustViewBounds="true"
						android:importantForAccessibility="no"
						android:scaleType="fitCenter"
						android:src="@drawable/ic_button_media_play"
						android:tint="@color/color_cardview_drawable_tint"
						android:visibility="visible"
						tools:ignore="ImageContrastCheck" />
				</RelativeLayout>
			</RelativeLayout>

			<!--
				PRIMARY ACTIONS ROW - PLAYBACK OPTIONS
				First button row containing immediate playback actions:
				internal player and external app opening.
				============================================================ -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<!-- Play in internal media player -->
				<LinearLayout
					android:id="@+id/btn_play_the_media"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:id="@+id/txt_play_the_media"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_player"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_play_the_video"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

				<!-- Open file with external applications -->
				<LinearLayout
					android:id="@+id/btn_open_download_file"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_0"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_8"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_open_v2"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_open_externally"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>
			</LinearLayout>

			<!--
				SHARING ACTIONS ROW - LINK AND FILE SHARING
				Second button row for sharing operations: copy source link
				and share downloaded file with other apps.
				============================================================ -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<!-- Copy original website URL to clipboard -->
				<LinearLayout
					android:id="@+id/btn_copy_site_link"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_clipboard_v2"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_copy_website_link"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

				<!-- Share file via Android share sheet -->
				<LinearLayout
					android:id="@+id/btn_share_download_file"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_0"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_8"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_share_v2"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_share_the_file"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>
			</LinearLayout>

			<!-- Visual separator between action categories -->
			<View
				android:layout_width="match_parent"
				android:layout_height="@dimen/_1"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_5"
				android:layout_marginBottom="@dimen/_5"
				android:background="@color/transparent_dark" />

			<!--
				FILE MANAGEMENT ROW - LIST AND STORAGE OPERATIONS
				Third button row for download list management and file deletion.
				Provides options to clear from list or permanently delete file.
				============================================================ -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<!-- Remove from downloads list without deleting file -->
				<LinearLayout
					android:id="@+id/btn_clear_download"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_clear"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_clear_from_list"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

				<!-- Permanently delete downloaded file from storage -->
				<LinearLayout
					android:id="@+id/btn_delete_download"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_0"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_8"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_delete_v2"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_delete_the_file"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>
			</LinearLayout>

			<!--
				ADVANCED ACTIONS ROW - FILE OPERATIONS
				Fourth button row for file manipulation and discovery:
				rename files and open source website.
				============================================================ -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<!-- Rename downloaded file -->
				<LinearLayout
					android:id="@+id/btn_rename_download"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_rename"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_rename_the_file"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

				<!-- Open source website in browser -->
				<LinearLayout
					android:id="@+id/btn_discover_more"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_0"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_8"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_browser"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_open_website"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>
			</LinearLayout>

			<!-- Visual separator between standard and advanced operations -->
			<View
				android:layout_width="match_parent"
				android:layout_height="@dimen/_1"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_5"
				android:layout_marginBottom="@dimen/_5"
				android:background="@color/transparent_dark" />

			<!--
				PRIVACY AND VISUAL CUSTOMIZATION ROW
				Fifth button row for privacy management and thumbnail controls:
				move to private folder and hide/remove thumbnails.
				============================================================ -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<!-- Move file to private/secure storage -->
				<LinearLayout
					android:id="@+id/btn_move_to_private"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:id="@+id/txt_move_to_private"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_private_folder"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_move_to_private"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

				<!-- Hide or remove file thumbnail -->
				<LinearLayout
					android:id="@+id/btn_remove_thumbnail"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_0"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_8"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:id="@+id/txt_remove_thumbnail"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_hide_eye"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_hide_thumbnail"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>
			</LinearLayout>

			<!-- Visual separator before advanced file operations -->
			<View
				android:layout_width="match_parent"
				android:layout_height="@dimen/_1"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_5"
				android:layout_marginBottom="@dimen/_5"
				android:background="@color/transparent_dark" />

			<!--
				FILE REPAIR OPERATION - MP4 FIXING
				Sixth row for advanced media file repair operations.
				Fixes unseekable MP4 files that have streaming compatibility issues.
				============================================================ -->
			<LinearLayout
				android:id="@+id/container_mp4_file_fix"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/_0"
				android:baselineAligned="false"
				android:orientation="horizontal"
				android:visibility="visible">

				<!-- Repair unseekable MP4 files for proper streaming -->
				<LinearLayout
					android:id="@+id/btn_fix_unseekable_mp4_file"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="UselessParent,TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_fix_hand"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_fix_unseekable_mp4_file_risky"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>
			</LinearLayout>

			<!--
				FILE CONVERSION OPERATION - MP4 TO MP3
				Seventh row for media format conversion.
				Converts video files to audio-only MP3 format.
				============================================================ -->
			<LinearLayout
				android:id="@+id/container_mp4_to_mp3_converter"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/_0"
				android:baselineAligned="false"
				android:orientation="horizontal"
				android:visibility="visible">

				<!-- Convert video file to MP3 audio format -->
				<LinearLayout
					android:id="@+id/btn_mp4_to_mp3_convert"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="UselessParent,TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_audio"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_convert_video_file_to_mp3_audio"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>
			</LinearLayout>

			<!--
				INFORMATION AND METADATA ROW
				Eighth and final row for technical information display.
				Shows detailed download system information and file metadata.
				============================================================ -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/_5"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<!-- Display detailed download information -->
				<LinearLayout
					android:id="@+id/btn_download_system_information"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="UselessParent,TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_information"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_download_system_information"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>
			</LinearLayout>
		</LinearLayout>
	</androidx.cardview.widget.CardView>
</LinearLayout>