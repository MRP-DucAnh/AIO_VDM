<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/style_dialog"
	android:layout_width="wrap_content"
	android:layout_height="wrap_content"
	tools:ignore="UseAppTint,UseCompatTextViewDrawableXml">

	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginStart="@dimen/_5"
		android:layout_marginTop="@dimen/_5"
		android:layout_marginEnd="@dimen/_5"
		android:layout_marginBottom="@dimen/_5"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_2">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="@dimen/_35"
				android:background="@color/color_cardview_title_bg"
				android:orientation="horizontal"
				android:visibility="visible"
				tools:ignore="TextSizeCheck">

				<TextView
					style="@style/style_dialog.title"
					android:layout_gravity="center"
					android:fontFamily="@font/font_family_bold"
					android:text="@string/title_sorting_downloads_by"
					android:textColor="@color/color_text_primary"
					android:textSize="@dimen/normal_text_size" />
			</LinearLayout>

			<RadioGroup
				android:id="@+id/sort_options_group"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginHorizontal="@dimen/_5"
				android:layout_marginVertical="@dimen/_5"
				android:orientation="vertical"
				android:textSize="@dimen/normal_text_size">

				<RadioButton
					android:id="@+id/button_sort_by_date_desc"
					android:layout_width="match_parent"
					android:layout_height="@dimen/_36"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_0"
					android:background="@drawable/ic_button_negative_selector"
					android:button="@drawable/ic_button_radio_selector"
					android:buttonTint="@color/color_secondary"
					android:drawableEnd="@drawable/ic_button_open_small"
					android:drawableTint="@color/color_secondary"
					android:fontFamily="@font/font_family_regular"
					android:paddingLeft="@dimen/_5"
					android:text="@string/title_sort_by_date_newest_first"
					android:textSize="@dimen/normal_text_size"
					tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize,TextSizeCheck" />

				<RadioButton
					android:id="@+id/button_sort_by_date_asc"
					android:layout_width="match_parent"
					android:layout_height="@dimen/_36"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_0"
					android:background="@drawable/ic_button_negative_selector"
					android:button="@drawable/ic_button_radio_selector"
					android:buttonTint="@color/color_secondary"
					android:drawableEnd="@drawable/ic_button_open_small"
					android:drawableTint="@color/color_secondary"
					android:fontFamily="@font/font_family_regular"
					android:paddingLeft="@dimen/_5"
					android:text="@string/title_sort_by_date_newest_last"
					android:textSize="@dimen/normal_text_size"
					tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize,TextSizeCheck" />

				<View
					android:layout_width="@dimen/_195"
					android:layout_height="@dimen/_1"
					android:layout_marginHorizontal="@dimen/_10"
					android:layout_marginVertical="@dimen/_5"
					android:alpha="0.5"
					android:background="@drawable/rounded_border_color" />

				<RadioButton
					android:id="@+id/button_sort_by_name_asc"
					android:layout_width="match_parent"
					android:layout_height="@dimen/_36"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_0"
					android:background="@drawable/ic_button_negative_selector"
					android:button="@drawable/ic_button_radio_selector"
					android:buttonTint="@color/color_secondary"
					android:drawableEnd="@drawable/ic_button_open_small"
					android:drawableTint="@color/color_secondary"
					android:fontFamily="@font/font_family_regular"
					android:paddingLeft="@dimen/_5"
					android:text="@string/title_sort_by_name_a_z"
					android:textSize="@dimen/normal_text_size"
					tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize" />

				<RadioButton
					android:id="@+id/button_sort_by_name_desc"
					android:layout_width="match_parent"
					android:layout_height="@dimen/_36"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_0"
					android:background="@drawable/ic_button_negative_selector"
					android:button="@drawable/ic_button_radio_selector"
					android:buttonTint="@color/color_secondary"
					android:drawableEnd="@drawable/ic_button_open_small"
					android:drawableTint="@color/color_secondary"
					android:fontFamily="@font/font_family_regular"
					android:paddingLeft="@dimen/_5"
					android:text="@string/title_sort_by_name_z_a"
					android:textSize="@dimen/normal_text_size"
					tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize" />

				<View
					android:layout_width="@dimen/_195"
					android:layout_height="@dimen/_1"
					android:layout_marginHorizontal="@dimen/_10"
					android:layout_marginVertical="@dimen/_5"
					android:alpha="0.5"
					android:background="@drawable/rounded_border_color" />

				<RadioButton
					android:id="@+id/button_sort_by_size_asc"
					android:layout_width="match_parent"
					android:layout_height="@dimen/_36"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_0"
					android:background="@drawable/ic_button_negative_selector"
					android:button="@drawable/ic_button_radio_selector"
					android:buttonTint="@color/color_secondary"
					android:drawableEnd="@drawable/ic_button_open_small"
					android:drawableTint="@color/color_secondary"
					android:fontFamily="@font/font_family_regular"
					android:paddingLeft="@dimen/_5"
					android:text="@string/sort_by_size_smallest_first"
					android:textSize="@dimen/normal_text_size"
					tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize,TextSizeCheck" />

				<RadioButton
					android:id="@+id/button_sort_by_size_desc"
					android:layout_width="match_parent"
					android:layout_height="@dimen/_36"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_5"
					android:background="@drawable/ic_button_negative_selector"
					android:button="@drawable/ic_button_radio_selector"
					android:buttonTint="@color/color_secondary"
					android:drawableEnd="@drawable/ic_button_open_small"
					android:drawableTint="@color/color_secondary"
					android:fontFamily="@font/font_family_regular"
					android:paddingLeft="@dimen/_5"
					android:text="@string/title_sort_by_size_largest_first"
					android:textSize="@dimen/normal_text_size"
					tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize,TextSizeCheck" />

				<View
					android:layout_width="@dimen/_195"
					android:layout_height="@dimen/_1"
					android:layout_marginHorizontal="@dimen/_10"
					android:layout_marginVertical="@dimen/_5"
					android:alpha="0.5"
					android:background="@drawable/rounded_border_color" />

				<RadioButton
					android:id="@+id/button_sort_by_videos"
					android:layout_width="match_parent"
					android:layout_height="@dimen/_36"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_0"
					android:background="@drawable/ic_button_negative_selector"
					android:button="@drawable/ic_button_radio_selector"
					android:buttonTint="@color/color_secondary"
					android:drawableEnd="@drawable/ic_button_open_small"
					android:drawableTint="@color/color_secondary"
					android:fontFamily="@font/font_family_regular"
					android:paddingLeft="@dimen/_5"
					android:text="@string/title_sort_by_size_videos_first"
					android:textSize="@dimen/normal_text_size"
					tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize,TextSizeCheck" />

				<RadioButton
					android:id="@+id/button_sort_by_music"
					android:layout_width="match_parent"
					android:layout_height="@dimen/_36"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_3"
					android:background="@drawable/ic_button_negative_selector"
					android:button="@drawable/ic_button_radio_selector"
					android:buttonTint="@color/color_secondary"
					android:drawableEnd="@drawable/ic_button_open_small"
					android:drawableTint="@color/color_secondary"
					android:fontFamily="@font/font_family_regular"
					android:paddingLeft="@dimen/_5"
					android:text="@string/title_sort_by_size_music_first"
					android:textSize="@dimen/normal_text_size"
					tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize" />

			</RadioGroup>
		</LinearLayout>
	</androidx.cardview.widget.CardView>
</LinearLayout>