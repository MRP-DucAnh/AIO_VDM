<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/style_dialog"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	tools:ignore="UseAppTint,UseCompatTextViewDrawableXml">

	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginHorizontal="@dimen/_5"
		android:layout_marginVertical="@dimen/_10"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_5">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="@color/color_cardview_title_bg"
				android:orientation="vertical">

				<TextView
					android:id="@+id/txt_dialog_title"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_margin="@dimen/_10"
					android:ellipsize="end"
					android:fontFamily="@font/font_family_bold"
					android:gravity="center"
					android:maxLines="1"
					android:text="@string/title_http_user_agent_selector"
					android:textColor="@color/color_text_primary"
					android:textSize="@dimen/normal_text_size" />
			</LinearLayout>

			<ScrollView
				android:layout_width="match_parent"
				android:layout_height="0dp"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_8"
				android:layout_marginEnd="@dimen/_10"
				android:layout_marginBottom="@dimen/_5"
				android:layout_weight="1">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">

					<TextView
						android:id="@+id/txt_dialog_message"
						style="@style/style_dialog.message"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_8"
						android:autoLink="web"
						android:fontFamily="@font/font_family_regular"
						android:text="@string/text_download_http_user_agent"
						android:textSize="@dimen/message_text_size" />

					<View
						android:layout_width="match_parent"
						android:layout_height="@dimen/_1"
						android:layout_marginHorizontal="@dimen/_5"
						android:layout_marginBottom="@dimen/_5"
						android:alpha="0.7"
						android:background="@color/color_border_gray" />

					<RadioGroup
						android:id="@+id/sort_options_group"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginHorizontal="@dimen/_10"
						android:orientation="vertical">

						<RadioButton
							android:id="@+id/btn_mobile_user_agent"
							android:layout_width="match_parent"
							android:layout_height="@dimen/_34"
							android:button="@null"
							android:checked="true"
							android:drawableStart="@drawable/ic_button_radio_selector"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_mobile_user_agent"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size"
							tools:ignore="VisualLintButtonSize,TouchTargetSizeCheck" />

						<RadioButton
							android:id="@+id/btn_desktop_user_agent"
							android:layout_width="match_parent"
							android:layout_height="@dimen/_38"
							android:layout_marginBottom="@dimen/_0"
							android:button="@null"
							android:checked="false"
							android:drawableStart="@drawable/ic_button_radio_selector"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_desktop_user_agent"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size"
							tools:ignore="VisualLintButtonSize,TouchTargetSizeCheck" />

						<RadioButton
							android:id="@+id/btn_custom_user_agent"
							android:layout_width="match_parent"
							android:layout_height="@dimen/_38"
							android:layout_marginBottom="@dimen/_0"
							android:button="@null"
							android:checked="false"
							android:drawableStart="@drawable/ic_button_radio_selector"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_custom_user_agent"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size"
							tools:ignore="VisualLintButtonSize,TouchTargetSizeCheck" />
					</RadioGroup>

					<LinearLayout
						android:id="@+id/edit_user_agent_container"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_5"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/rounded_surface_color"
						android:clickable="true"
						android:orientation="vertical"
						android:visibility="gone"
						tools:ignore="TouchTargetSizeCheck">

						<EditText
							android:id="@+id/edit_user_agent"
							style="@style/style_dialog.message"
							android:layout_width="match_parent"
							android:layout_margin="@dimen/_8"
							android:background="@color/transparent"
							android:drawableStart="@drawable/ic_button_browser_favicon"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:gravity="center_vertical"
							android:hint="@string/title_enter_custom_user_agent"
							android:importantForAutofill="no"
							android:inputType="textUri"
							android:maxLines="1"
							android:singleLine="true"
							android:textColor="@color/color_on_surface"
							android:textColorHint="@color/color_text_hint"
							android:textSize="@dimen/normal_text_size"
							android:textStyle="normal"
							tools:ignore="TextContrastCheck,TouchTargetSizeCheck,VisualLintTextFieldSize" />

					</LinearLayout>
				</LinearLayout>
			</ScrollView>

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/_5"
				android:baselineAligned="true"
				android:orientation="horizontal">

				<RelativeLayout
					android:id="@+id/button_dialog_negative_container"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="@dimen/_10"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_10"
					android:layout_marginBottom="@dimen/_5"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:visibility="gone"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:id="@+id/button_dialog_negative"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_centerInParent="true"
						android:layout_margin="@dimen/_7"
						android:drawableStart="@drawable/ic_button_cancel"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_text_primary"
						android:ellipsize="end"
						android:fontFamily="@font/font_family_medium"
						android:gravity="center"
						android:maxLines="1"
						android:text="@string/title_cancel"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</RelativeLayout>

				<RelativeLayout
					android:id="@+id/btn_dialog_positive_container"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="@dimen/_10"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_10"
					android:layout_marginBottom="@dimen/_5"
					android:layout_weight="1"
					android:background="@drawable/ic_button_selector_secondary"
					android:clickable="true"
					android:elevation="@dimen/_2"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:id="@+id/btn_dialog_positive"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_centerInParent="true"
						android:layout_margin="@dimen/_7"
						android:drawableStart="@drawable/ic_button_checked_circle"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_on_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/font_family_semibold"
						android:gravity="center"
						android:maxLines="1"
						android:text="@string/title_apply_changes"
						android:textColor="@color/color_on_secondary"
						android:textSize="@dimen/normal_text_size"
						tools:ignore="TextContrastCheck" />
				</RelativeLayout>
			</LinearLayout>
		</LinearLayout>
	</androidx.cardview.widget.CardView>
</LinearLayout>