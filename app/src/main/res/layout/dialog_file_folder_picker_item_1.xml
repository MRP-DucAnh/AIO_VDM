<?xml version="1.0" encoding="utf-8"?>
<!-- =========================================================================
     Completed Download Item Row Layout
     Displays a single completed download item with file type indicator,
     file/folder information, and selection checkbox. Used in lists showing
     finished downloads for user interaction and management.

     This row layout represents a completed download in the downloads history
     or file browser, providing essential file metadata and selection capabilities
     for batch operations like sharing, moving, or deleting multiple files.

     Visual Hierarchy:
     - Left: File type icon indicating document, image, video, etc.
     - Center: File name and metadata (size, date, format)
     - Right: Selection checkbox for multi-select operations
     - Entire row: Clickable for individual file actions
     ========================================================================= -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/button_finish_download_row"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:background="@drawable/ic_button_negative_selector"
	android:clickable="true"
	tools:ignore="UseAppTint, UselessParent">

	<!-- ============================================================
	     FILE TYPE INDICATOR ICON
	     Visual representation of the file type (document, image, video,
	     audio, etc.) using standardized icons. Helps users quickly
	     identify file categories without reading text descriptions.
     ============================================================ -->
	<ImageView
		android:id="@+id/img_file_type_indicator"
		android:layout_width="@dimen/_30"
		android:layout_height="wrap_content"
		android:layout_alignParentLeft="true"
		android:layout_centerVertical="true"
		android:layout_marginHorizontal="@dimen/_5"
		android:adjustViewBounds="true"
		android:importantForAccessibility="no"
		android:src="@drawable/img_file_indicator"
		tools:ignore="ImageContrastCheck" />

	<!-- ============================================================
	     FILE/FOLDER INFORMATION CONTAINER
	     Central area displaying the primary file metadata in vertical
     stack. Positioned between the file type icon and selection checkbox
     to maximize text area while maintaining balanced visual proportions.

     Contains:
     - File/folder name (primary identifier)
     - Metadata (file size, modification date, format details)
     ============================================================ -->
	<LinearLayout
		android:id="@+id/container_file_folder_info"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginHorizontal="@dimen/_5"
		android:layout_marginVertical="@dimen/_2"
		android:layout_toStartOf="@+id/img_checkbox_selection"
		android:layout_toEndOf="@+id/img_file_type_indicator"
		android:orientation="vertical">

		<!-- ======================================================
		     FILE/FOLDER NAME
		     Primary text display showing the actual name of the
		     downloaded file or folder. Uses primary text color
		     and standard message text size for clear readability.

		     Expected content: Actual file name with extension
		     (e.g., "document.pdf", "vacation_photo.jpg")
		     ====================================================== -->
		<TextView
			android:id="@+id/txt_file_folder_name"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/title_sample_folder_name"
			android:textColor="@color/color_text_primary"
			android:textFontWeight="400"
			android:textSize="@dimen/message_text_size" />

		<!-- ======================================================
		     FILE METADATA INFORMATION
		     Secondary text line displaying additional file details
		     such as file size, download date, format information,
		     or duration for media files. Uses smaller text size
		     and maintains primary color for consistency.

		     Expected content: Formatted metadata string
		     (e.g., "15.2 MB • PDF • Jan 15, 2024")
		     ====================================================== -->
		<TextView
			android:id="@+id/txt_file_folder_metadata"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/title_sample_folder_name"
			android:textColor="@color/color_text_primary"
			android:textFontWeight="400"
			android:textSize="@dimen/smaller_text_size" />
	</LinearLayout>

	<!-- ============================================================
	     SELECTION CHECKBOX INDICATOR
	     Visual indicator for file selection state in multi-select mode.
	      Shows checked/unchecked state and allows users to select multiple
	      files for batch operations like delete, share, or move.
     ============================================================ -->
	<ImageView
		android:id="@+id/img_checkbox_selection"
		android:layout_width="@dimen/_20"
		android:layout_height="wrap_content"
		android:layout_alignParentRight="true"
		android:layout_centerVertical="true"
		android:layout_marginHorizontal="@dimen/_5"
		android:adjustViewBounds="true"
		android:importantForAccessibility="no"
		android:src="@drawable/ic_image_selection"
		android:visibility="gone" />

</RelativeLayout>