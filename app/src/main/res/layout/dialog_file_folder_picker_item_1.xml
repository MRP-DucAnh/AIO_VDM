<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/button_finish_download_row"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:layout_marginHorizontal="@dimen/_5"
	android:background="@drawable/ic_button_negative_selector"
	android:clickable="true"
	tools:ignore="UseAppTint, UselessParent">

	<ImageView
		android:id="@+id/img_file_type_indicator"
		android:layout_width="@dimen/_30"
		android:layout_height="wrap_content"
		android:layout_alignParentLeft="true"
		android:layout_centerVertical="true"
		android:layout_marginHorizontal="@dimen/_5"
		android:adjustViewBounds="true"
		android:importantForAccessibility="no"
		android:src="@drawable/img_folder_indicator"
		tools:ignore="ImageContrastCheck" />

	<LinearLayout
		android:id="@+id/container_file_folder_info"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginHorizontal="@dimen/_5"
		android:layout_marginVertical="@dimen/_2"
		android:layout_toStartOf="@+id/img_checkbox_selection"
		android:layout_toEndOf="@+id/img_file_type_indicator"
		android:orientation="vertical">

		<TextView
			android:id="@+id/txt_file_folder_name"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:drawableRight="@drawable/ic_button_open_small"
			android:drawableTint="@color/color_secondary"
			android:fontFamily="@font/font_family_semibold"
			android:text="@string/title_sample_folder_name"
			android:textColor="@color/color_text_primary"
			android:textSize="@dimen/normal_text_size_small"
			tools:ignore="UseCompatTextViewDrawableXml" />

		<TextView
			android:id="@+id/txt_file_folder_metadata"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="-4dp"
			android:fontFamily="@font/font_family_medium"
			android:text="@string/title_sample_folder_name"
			android:textColor="@color/color_text_primary"
			android:textSize="@dimen/small_text_size" />
	</LinearLayout>

	<ImageView
		android:id="@+id/img_checkbox_selection"
		android:layout_width="@dimen/_20"
		android:layout_height="wrap_content"
		android:layout_alignParentRight="true"
		android:layout_centerVertical="true"
		android:layout_marginHorizontal="@dimen/_5"
		android:adjustViewBounds="true"
		android:importantForAccessibility="no"
		android:src="@drawable/ic_image_selection"
		android:visibility="gone" />

</RelativeLayout>