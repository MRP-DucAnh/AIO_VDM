<?xml version="1.0" encoding="utf-8"?><!-- Dialog layout for download task options with thumbnail and action buttons -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/style_dialog"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	tools:ignore="UseAppTint,UseCompatTextViewDrawableXml">

	<!-- Main card container with rounded corners and shadow -->
	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginStart="@dimen/_5"
		android:layout_marginTop="@dimen/_10"
		android:layout_marginEnd="@dimen/_5"
		android:layout_marginBottom="@dimen/_10"
		app:cardBackgroundColor="@color/color_background"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_5">

		<!-- Vertical layout for organizing dialog content -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<RelativeLayout
				android:id="@+id/btn_file_info_card"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginStart="@dimen/_8"
				android:layout_marginTop="@dimen/_8"
				android:layout_marginEnd="@dimen/_8"
				android:layout_marginBottom="@dimen/_8"
				android:background="@drawable/ic_button_cardview_selector"
				android:clickable="true"
				android:elevation="@dimen/_2"
				tools:ignore="DuplicateSpeakableTextCheck">

				<androidx.cardview.widget.CardView
					android:id="@+id/thumbnail_container"
					android:layout_width="@dimen/_85"
					android:layout_height="@dimen/_52"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_0"
					android:layout_marginBottom="@dimen/_5"
					android:background="@color/transparent"
					app:cardCornerRadius="@dimen/_5">

					<ImageView
						android:id="@+id/img_media_play_indicator"
						android:layout_width="@dimen/_17"
						android:layout_height="wrap_content"
						android:layout_gravity="center"
						android:adjustViewBounds="true"
						android:elevation="@dimen/_5"
						android:importantForAccessibility="no"
						android:src="@drawable/image_media_play"
						android:tint="@color/color_on_primary"
						android:visibility="visible"
						tools:ignore="ImageContrastCheck" />

					<ImageView
						android:id="@+id/img_file_thumbnail"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_centerVertical="true"
						android:adjustViewBounds="true"
						android:importantForAccessibility="no"
						android:scaleType="centerCrop"
						android:src="@drawable/image_no_thumb_available"
						tools:ignore="ImageContrastCheck" />

					<ImageView
						android:id="@+id/img_site_favicon"
						android:layout_width="@dimen/_15"
						android:layout_height="wrap_content"
						android:layout_gravity="start|top"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_3"
						android:adjustViewBounds="true"
						android:elevation="@dimen/_5"
						android:importantForAccessibility="no"
						android:src="@drawable/ic_image_default_favicon"
						android:visibility="visible"
						tools:ignore="ImageContrastCheck" />

					<ImageView
						android:id="@+id/img_file_type_indicator"
						android:layout_width="@dimen/_17"
						android:layout_height="wrap_content"
						android:layout_gravity="start|bottom"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_5"
						android:layout_marginBottom="@dimen/_3"
						android:adjustViewBounds="true"
						android:background="@drawable/rounded_pure_black_color"
						android:elevation="@dimen/_2"
						android:importantForAccessibility="no"
						android:src="@drawable/ic_button_video"
						android:tint="@color/color_on_primary"
						android:visibility="visible"
						tools:ignore="ImageContrastCheck" />

					<ImageView
						android:id="@+id/img_private_folder_indicator"
						android:layout_width="@dimen/_17"
						android:layout_height="wrap_content"
						android:layout_gravity="end|bottom"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_5"
						android:layout_marginEnd="@dimen/_5"
						android:layout_marginBottom="@dimen/_3"
						android:adjustViewBounds="true"
						android:background="@drawable/rounded_pure_black_color"
						android:elevation="@dimen/_2"
						android:importantForAccessibility="no"
						android:src="@drawable/ic_button_folder"
						android:tint="@color/color_on_primary"
						android:visibility="visible"
						tools:ignore="ImageContrastCheck" />

					<LinearLayout
						android:id="@+id/container_media_duration"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_gravity="end"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_3"
						android:layout_marginEnd="@dimen/_5"
						android:layout_marginBottom="@dimen/_5"
						android:background="@drawable/rounded_pure_black_color"
						android:orientation="vertical"
						android:visibility="visible">

						<TextView
							android:id="@+id/txt_media_duration"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginStart="@dimen/_5"
							android:layout_marginTop="-3dp"
							android:layout_marginEnd="@dimen/_5"
							android:layout_marginBottom="@dimen/_1"
							android:fontFamily="@font/application_font_family"
							android:text="@string/title_time_representation"
							android:textColor="@color/color_on_primary"
							android:textFontWeight="700"
							android:textSize="@dimen/smallest_text_size"
							android:textStyle="normal"
							tools:ignore="TextContrastCheck,VisualLintBounds" />
					</LinearLayout>
				</androidx.cardview.widget.CardView>

				<RelativeLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_centerVertical="true"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginEnd="@dimen/_5"
					android:layout_toEndOf="@+id/thumbnail_container"
					android:orientation="vertical">

					<TextView
						android:id="@+id/txt_file_title"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="-2dp"
						android:layout_marginBottom="@dimen/_5"
						android:layout_toStartOf="@+id/img_open_file"
						android:ellipsize="marquee"
						android:focusable="true"
						android:focusableInTouchMode="true"
						android:fontFamily="@font/application_font_family"
						android:gravity="center_vertical"
						android:marqueeRepeatLimit="marquee_forever"
						android:scrollHorizontally="true"
						android:singleLine="true"
						android:text="@string/title__"
						android:textColor="@color/color_on_primary"
						android:textFontWeight="700"
						android:textSize="@dimen/sub_heading_text_size"
						tools:ignore="VisualLintBounds" />

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_below="@id/txt_file_title"
						android:layout_marginEnd="@dimen/_5"
						android:alpha="0.5"
						android:background="@drawable/rounded_transparent_white_f5"
						android:orientation="vertical">

						<TextView
							android:id="@+id/txt_file_url"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginStart="@dimen/_5"
							android:layout_marginTop="@dimen/_2"
							android:layout_marginEnd="@dimen/_5"
							android:layout_marginBottom="@dimen/_2"
							android:alpha="1"
							android:ellipsize="end"
							android:fontFamily="@font/application_font_family"
							android:gravity="left|center_vertical"
							android:singleLine="true"
							android:text="@string/title__"
							android:textColor="@color/color_on_primary"
							android:textFontWeight="500"
							android:textSize="@dimen/small_text_size"
							android:textStyle="italic"
							tools:ignore="TextContrastCheck" />
					</LinearLayout>

					<ImageView
						android:id="@+id/img_open_file"
						android:layout_width="@dimen/_20"
						android:layout_height="@dimen/_20"
						android:layout_alignParentEnd="true"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginEnd="@dimen/_5"
						android:adjustViewBounds="true"
						android:importantForAccessibility="no"
						android:scaleType="fitCenter"
						android:src="@drawable/ic_button_media_play"
						android:tint="@color/color_cardview_drawable_tint"
						android:visibility="visible"
						tools:ignore="ImageContrastCheck" />
				</RelativeLayout>
			</RelativeLayout>

			<!-- First row of action buttons: Resume and Pause -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<!-- Resume download button -->
				<LinearLayout
					android:id="@+id/btn_resume_download"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_media_play"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_green"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_resume_task"
						android:textColor="@color/color_green"
						android:textFontWeight="700"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

				<!-- Pause download button -->
				<LinearLayout
					android:id="@+id/btn_pause_download"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_0"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_8"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_media_pause"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_error"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_pause_task"
						android:textColor="@color/color_error"
						android:textFontWeight="700"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>
			</LinearLayout>

			<!-- Divider line -->
			<View
				android:layout_width="match_parent"
				android:layout_height="@dimen/_1"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_5"
				android:layout_marginBottom="@dimen/_5"
				android:background="@color/transparent_dark" />

			<!-- Second row of action buttons: Clear and Delete -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<!-- Clear from list button -->
				<LinearLayout
					android:id="@+id/btn_clear_download"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_clear"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_clear_from_list"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

				<!-- Delete file button -->
				<LinearLayout
					android:id="@+id/btn_delete_download"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_0"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_8"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_delete_v2"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_delete_the_file"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>
			</LinearLayout>

			<!-- Third row of action buttons: Rename file and hide thumbnail -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:baselineAligned="false"
				android:orientation="horizontal">
				<!-- Rename file button -->
				<LinearLayout
					android:id="@+id/btn_rename_download"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_rename"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_rename_the_file"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

				<!-- Discover more/Open link button -->
				<LinearLayout
					android:id="@+id/btn_remove_thumbnail"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_0"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_8"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:id="@+id/txt_remove_thumbnail"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_hide_eye"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_hide_thumbnail"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

			</LinearLayout>

			<!-- Divider line -->
			<View
				android:layout_width="match_parent"
				android:layout_height="@dimen/_1"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_5"
				android:layout_marginBottom="@dimen/_5"
				android:background="@color/transparent_dark" />

			<!-- Fourth row of action buttons: Copy site link and Open site -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<!-- Copy site link button -->
				<LinearLayout
					android:id="@+id/btn_copy_site_link"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_www"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_copy_website_link"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

				<!-- Open link button -->
				<LinearLayout
					android:id="@+id/btn_open_website"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_0"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_8"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_browser"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_open_website"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>
			</LinearLayout>

			<!-- Fifth row of action buttons: Share and Copy URL-->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<!-- Copy file link button -->
				<LinearLayout
					android:id="@+id/btn_copy_download_url"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_clipboard"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_copy_file_link"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

				<!-- Share file link button -->
				<LinearLayout
					android:id="@+id/btn_share_download_url"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_0"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_8"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_share_v2"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_share_file_link"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

			</LinearLayout>

			<!-- Divider line -->
			<View
				android:layout_width="match_parent"
				android:layout_height="@dimen/_1"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_5"
				android:layout_marginBottom="@dimen/_5"
				android:background="@color/transparent_dark" />

			<!-- Six of action buttons: Speed limiter and expire link -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<!-- Rename file button -->
				<LinearLayout
					android:id="@+id/btn_update_expire_link"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_8"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_rename"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:singleLine="true"
						android:text="@string/title_update_link"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

				<!-- Discover more/Open link button -->
				<LinearLayout
					android:id="@+id/btn_speed_limiter"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_marginStart="@dimen/_0"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_8"
					android:layout_marginBottom="@dimen/_0"
					android:layout_weight="1"
