<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/style_dialog"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	tools:ignore="UseAppTint,UseCompatTextViewDrawableXml">

	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginHorizontal="@dimen/_5"
		android:layout_marginVertical="@dimen/_10"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_5">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="@color/color_cardview_title_bg"
				android:orientation="vertical"
				android:visibility="gone">

				<TextView
					android:id="@+id/txt_dialog_title"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_margin="@dimen/_10"
					android:ellipsize="end"
					android:fontFamily="@font/font_family_bold"
					android:gravity="center"
					android:maxLines="1"
					android:text="@string/title_update_profile_detail"
					android:textColor="@color/color_text_primary"
					android:textSize="@dimen/normal_text_size" />
			</LinearLayout>

			<ScrollView
				android:layout_width="match_parent"
				android:layout_height="0dp"
				android:layout_marginHorizontal="@dimen/_10"
				android:layout_weight="1">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">

					<LinearLayout
						android:id="@+id/container_edit_field_name"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_0"
						android:layout_marginLeft="@dimen/_0"
						android:layout_marginTop="@dimen/_10"
						android:layout_marginEnd="@dimen/_0"
						android:layout_marginRight="@dimen/_0"
						android:layout_marginBottom="@dimen/_8"
						android:background="@drawable/rounded_surface_color"
						android:clipChildren="false"
						android:clipToPadding="false"
						android:orientation="vertical">

						<EditText
							android:id="@+id/edit_field_name"
							style="@style/style_dialog.message"
							android:layout_margin="@dimen/_8"
							android:background="@color/transparent"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:drawableStart="@drawable/ic_button_user_name"
							android:drawableLeft="@drawable/ic_button_user_name"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:gravity="center_vertical"
							android:hint="@string/title_your_full_name"
							android:importantForAutofill="no"
							android:inputType="textUri"
							android:maxLines="1"
							android:singleLine="true"
							android:textColor="@color/color_on_surface"
							android:textColorHint="@color/color_text_hint"
							android:textSize="@dimen/normal_text_size"
							android:textStyle="normal"
							tools:ignore="RtlHardcoded,TextContrastCheck,
							TouchTargetSizeCheck,VisualLintTextFieldSize" />
					</LinearLayout>

					<RelativeLayout
						android:id="@+id/btn_update_profile_details"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_25"
						android:layout_marginLeft="@dimen/_25"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_25"
						android:layout_marginRight="@dimen/_25"
						android:layout_marginBottom="@dimen/_5"
						android:background="@drawable/ic_button_selector_secondary"
						android:clickable="true"
						android:elevation="@dimen/_2"
						tools:ignore="RtlHardcoded,TouchTargetSizeCheck">

						<TextView
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_centerInParent="true"
							android:layout_margin="@dimen/_7"
							android:drawableStart="@drawable/ic_button_saved"
							android:drawableLeft="@drawable/ic_button_saved"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_on_secondary"
							android:fontFamily="@font/font_family_semibold"
							android:gravity="center"
							android:text="@string/title_update_username"
							android:textColor="@color/color_on_secondary"
							android:textSize="@dimen/normal_text_size"
							tools:ignore="UseCompatTextViewDrawableXml" />
					</RelativeLayout>

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_gravity="center_horizontal"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginLeft="@dimen/_10"
						android:layout_marginTop="@dimen/_2"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginRight="@dimen/_10"
						android:layout_marginBottom="@dimen/_8"
						android:fontFamily="@font/font_family_regular"
						android:text="@string/title_change_or_update_profile_name"
						android:textColor="@color/color_text_secondary"
						android:textSize="@dimen/small_text_size_x2" />
				</LinearLayout>
			</ScrollView>
		</LinearLayout>
	</androidx.cardview.widget.CardView>
</LinearLayout>