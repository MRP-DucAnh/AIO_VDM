<?xml version="1.0" encoding="utf-8"?>
<!--
    Active Download Task Row Layout
    This layout represents a single download item in progress with visual indicators
    for status, progress, and file type. Features thumbnail display with multiple
    overlay indicators and real-time download status updates.
    ============================================================================== -->

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/button_finish_download_row"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:background="@color/transparent"
	android:clickable="true"
	tools:ignore="UseAppTint, UselessParent">

	<!--
		MAIN CARD CONTAINER
		Provides elevated card appearance with rounded corners and margin spacing
		between rows. Serves as the primary visual container for the download item.
		========================================================================= -->
	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginStart="@dimen/_10"
		android:layout_marginTop="@dimen/_3"
		android:layout_marginEnd="@dimen/_10"
		android:layout_marginBottom="@dimen/_5"
		android:orientation="vertical"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10">

		<!--
			MAIN ROW CONTAINER
			Wraps all content with a selector background for touch feedback.
			Contains thumbnail area and file information section.
			=============================================================== -->
		<RelativeLayout
			android:id="@+id/main_row_container"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:background="@drawable/ic_button_selector_background">

			<!--
				THUMBNAIL CONTAINER CARD
				Houses the file thumbnail with multiple overlay indicators.
				Uses CardView for rounded corners and consistent styling.
				========================================================== -->
			<androidx.cardview.widget.CardView
				android:id="@+id/thumbnail_container"
				android:layout_width="@dimen/_90"
				android:layout_height="@dimen/_57"
				android:layout_marginStart="@dimen/_5"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_5"
				android:layout_marginBottom="@dimen/_5"
				app:cardBackgroundColor="@color/color_cardview_bg"
				app:cardCornerRadius="@dimen/_5">

				<!--
					FILE THUMBNAIL IMAGE
					Primary thumbnail display with fallback image.
					Uses centerCrop scaling to fill container while maintaining aspect ratio.
					======================================================================= -->
				<ImageView
					android:id="@+id/img_file_thumbnail"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_centerVertical="true"
					android:adjustViewBounds="true"
					android:importantForAccessibility="no"
					android:scaleType="centerCrop"
					android:src="@drawable/image_no_thumb_available"
					tools:ignore="ImageContrastCheck" />

				<!--
					PLAY INDICATOR OVERLAY
					Shows play icon for media files (video/audio).
					Hidden by default, shown only for playable media types.
					====================================================== -->
				<ImageView
					android:id="@+id/img_media_play_indicator"
					android:layout_width="@dimen/_20"
					android:layout_height="wrap_content"
					android:layout_gravity="center"
					android:adjustViewBounds="true"
					android:elevation="@dimen/_5"
					android:importantForAccessibility="no"
					android:src="@drawable/image_media_play"
					android:tint="@color/color_on_primary"
					android:visibility="gone"
					tools:ignore="ImageContrastCheck" />

				<!--
					SITE FAVICON INDICATOR
					Displays source website favicon for downloaded content.
					Positioned at top-start corner, hidden by default.
					==================================================== -->
				<ImageView
					android:id="@+id/img_site_favicon"
					android:layout_width="@dimen/_20"
					android:layout_height="wrap_content"
					android:layout_gravity="start|top"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:adjustViewBounds="true"
					android:elevation="@dimen/_5"
					android:importantForAccessibility="no"
					android:src="@drawable/ic_button_information"
					android:visibility="gone"
					tools:ignore="ImageContrastCheck" />

				<!--
					FILE TYPE INDICATOR
					Shows icon representing file type (video, audio, document, etc.).
					Positioned at bottom-start corner with semi-transparent background.
					================================================================== -->
				<ImageView
					android:id="@+id/img_file_type_indicator"
					android:layout_width="@dimen/_20"
					android:layout_height="wrap_content"
					android:layout_gravity="start|bottom"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginBottom="@dimen/_5"
					android:adjustViewBounds="true"
					android:background="@drawable/rounded_transparent_black"
					android:elevation="@dimen/_2"
					android:importantForAccessibility="no"
					android:src="@drawable/ic_button_video"
					android:tint="@color/color_on_primary"
					android:visibility="visible"
					tools:ignore="ImageContrastCheck" />

				<!--
					PRIVATE FOLDER INDICATOR
					Shows lock/folder icon when download is in private storage.
					Positioned at bottom-end corner, indicates secure storage.
					========================================================== -->
				<ImageView
					android:id="@+id/img_private_folder_indicator"
					android:layout_width="@dimen/_20"
					android:layout_height="wrap_content"
					android:layout_gravity="end|bottom"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_5"
					android:adjustViewBounds="true"
					android:background="@drawable/rounded_transparent_black"
					android:elevation="@dimen/_2"
					android:importantForAccessibility="no"
					android:src="@drawable/ic_button_folder"
					android:tint="@color/color_on_primary"
					android:visibility="visible"
					tools:ignore="ImageContrastCheck" />

				<!--
					SELECTION CHECKBOX
					Used for multi-selection mode in download management.
					Shows checkmark when item is selected, hidden by default.
					======================================================= -->
				<ImageView
					android:id="@+id/img_checkbox_selection"
					android:layout_width="@dimen/_30"
					android:layout_height="wrap_content"
					android:layout_alignParentStart="true"
					android:layout_gravity="center_vertical|center_horizontal"
					android:adjustViewBounds="true"
					android:elevation="@dimen/_5"
					android:importantForAccessibility="no"
					android:src="@drawable/media3_icon_check_circle_filled"
					android:tint="@color/color_secondary"
					android:visibility="gone" />

				<!--
					MEDIA DURATION CONTAINER
					Shows video/audio duration in a rounded badge.
					Hidden by default, shown only for media with known duration.
					========================================================== -->
				<LinearLayout
					android:id="@+id/container_media_duration"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_gravity="end"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_5"
					android:background="@drawable/rounded_primary_color"
					android:orientation="vertical"
					android:visibility="gone">

					<!-- Duration text formatted as HH:MM:SS or MM:SS -->
					<TextView
						android:id="@+id/txt_media_duration"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_1"
						android:layout_marginEnd="@dimen/_5"
						android:layout_marginBottom="@dimen/_1"
						android:fontFamily="@font/application_font_family"
						android:text="@string/title_time_representation"
						android:textColor="@color/color_on_primary"
						android:textSize="@dimen/small_text_size"
						android:textStyle="normal"
						tools:ignore="TextContrastCheck" />
				</LinearLayout>
			</androidx.cardview.widget.CardView>

			<!--
				FILE INFORMATION CONTAINER
				Contains file name, status, and action buttons.
				Positioned to the right of the thumbnail container.
				================================================== -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_centerVertical="true"
				android:layout_marginEnd="@dimen/_8"
				android:layout_toEndOf="@id/thumbnail_container"
				android:orientation="vertical">

				<!--
					FILE NAME AND ACTION ROW
					Contains file name text and open/action button.
					Uses RelativeLayout for flexible text truncation around action button.
					===================================================================== -->
				<RelativeLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content">

					<!--
						FILE NAME TEXT
						Displays download file name with 2-line maximum.
						Automatically truncates to accommodate action button.
						=================================================== -->
					<TextView
						android:id="@+id/txt_file_name"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_toStartOf="@id/img_status_indicator"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:gravity="center_vertical"
						android:maxLines="2"
						android:singleLine="false"
						android:text="@string/text_sample_video_file_name"
						android:textColor="@color/color_text_primary"
						android:textFontWeight="500"
						android:textSize="@dimen/normal_text_size_small" />

					<!--
						OPEN/ACTION BUTTON
						Provides quick access to file actions (open, share, etc.).
						Positioned at the end of the file name row.
						======================================================== -->
					<ImageView
						android:id="@+id/img_status_indicator"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_alignParentEnd="true"
						android:layout_centerVertical="true"
						android:layout_marginStart="@dimen/_5"
						android:adjustViewBounds="true"
						android:importantForAccessibility="no"
						android:src="@drawable/ic_button_open_v2"
						android:tint="@color/color_secondary"
						tools:ignore="ImageContrastCheck" />

				</RelativeLayout>

				<!--
					DOWNLOAD STATUS CONTAINER
					Shows current download progress, speed, and status information.
					Uses rounded background for visual separation from file name.
					============================================================= -->
				<RelativeLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="@dimen/_3"
					android:background="@drawable/rounded_surface_color"
					android:orientation="horizontal">

					<!--
						DOWNLOAD STATUS TEXT
						Displays progress percentage, download speed, file size, etc.
						Single line with ellipsis for overflow handling.
						=========================================================== -->
					<TextView
						android:id="@+id/txt_download_status"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_alignParentStart="true"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_2"
						android:layout_marginEnd="@dimen/_5"
						android:layout_marginBottom="@dimen/_2"
						android:layout_toStartOf="@id/img_active_indicator"
						android:ellipsize="none"
						android:fontFamily="@font/application_font_family"
						android:gravity="center_vertical"
						android:singleLine="true"
						android:text="@string/title__"
						android:textColor="@color/color_text_hint"
						android:textSize="@dimen/smallest_text_size"
						tools:ignore="TextContrastCheck" />

					<!--
						ACTIVE DOWNLOAD INDICATOR
						Animated dot or icon showing download is in progress.
						Provides visual feedback that transfer is active.
						=================================================== -->
					<ImageView
						android:id="@+id/img_active_indicator"
						android:layout_width="@dimen/_15"
						android:layout_height="wrap_content"
						android:layout_alignParentEnd="true"
						android:layout_centerVertical="true"
						android:layout_marginEnd="@dimen/_5"
						android:adjustViewBounds="true"
						android:importantForAccessibility="yes"
						android:src="@drawable/ic_button_dot"
						android:tint="@color/color_secondary"
						android:visibility="visible"
						tools:ignore="ContentDescription,ImageContrastCheck" />

				</RelativeLayout>
			</LinearLayout>
		</RelativeLayout>
	</androidx.cardview.widget.CardView>
</RelativeLayout>