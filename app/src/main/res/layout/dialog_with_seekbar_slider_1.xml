<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/style_dialog"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	tools:ignore="UseAppTint,UseCompatTextViewDrawableXml">

	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginHorizontal="@dimen/_5"
		android:layout_marginVertical="@dimen/_10"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_5">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="@color/color_cardview_title_bg"
				android:orientation="vertical">

				<TextView
					android:id="@+id/txt_dialog_title"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_margin="@dimen/_10"
					android:ellipsize="end"
					android:fontFamily="@font/font_family_bold"
					android:gravity="center"
					android:maxLines="1"
					android:text="@string/title__"
					android:textColor="@color/color_text_primary"
					android:textSize="@dimen/normal_text_size" />
			</LinearLayout>

			<ScrollView
				android:id="@+id/message_body_container"
				android:layout_width="match_parent"
				android:layout_height="0dp"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_8"
				android:layout_marginEnd="@dimen/_10"
				android:layout_marginBottom="@dimen/_8"
				android:layout_weight="1">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">

					<TextView
						android:id="@+id/txt_dialog_message"
						style="@style/style_dialog.message"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:autoLink="web"
						android:fontFamily="@font/font_family_regular"
						android:text="@string/title_message_goes_here"
						android:textSize="@dimen/message_text_size" />

					<TextView
						android:id="@+id/txt_seekbar_progress"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_gravity="center_horizontal"
						android:layout_marginTop="@dimen/_8"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/rounded_primary_dark_color"
						android:fontFamily="@font/font_family_semibold"
						android:paddingStart="@dimen/_15"
						android:paddingTop="@dimen/_2"
						android:paddingEnd="@dimen/_15"
						android:paddingBottom="@dimen/_2"
						android:text="@string/title_0"
						android:textColor="@color/color_on_primary" />

					<SeekBar
						android:id="@+id/seekbar_slider"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_centerHorizontal="true"
						android:layout_marginHorizontal="@dimen/_25"
						android:layout_marginTop="@dimen/_3"
						android:max="100"
						android:thumb="@drawable/image_button_scrubber"
						tools:ignore="ObsoleteLayoutParam" />

				</LinearLayout>
			</ScrollView>

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/_5"
				android:baselineAligned="true"
				android:orientation="horizontal">

				<RelativeLayout
					android:id="@+id/button_dialog_negative_container"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="@dimen/_10"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_10"
					android:layout_marginBottom="@dimen/_5"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:id="@+id/button_dialog_negative"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_centerInParent="true"
						android:layout_margin="@dimen/_7"
						android:drawableStart="@drawable/ic_button_cancel"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_text_primary"
						android:ellipsize="end"
						android:fontFamily="@font/font_family_medium"
						android:gravity="center"
						android:maxLines="1"
						android:text="@string/title_cancel"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</RelativeLayout>

				<RelativeLayout
					android:id="@+id/btn_dialog_positive_container"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="@dimen/_10"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_10"
					android:layout_marginBottom="@dimen/_5"
					android:layout_weight="1"
					android:background="@drawable/ic_button_selector_secondary"
					android:clickable="true"
					android:elevation="@dimen/_2"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:id="@+id/btn_dialog_positive"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_centerInParent="true"
						android:layout_margin="@dimen/_7"
						android:drawableStart="@drawable/ic_button_checked_circle"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_on_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/font_family_semibold"
						android:gravity="center"
						android:maxLines="1"
						android:text="@string/title_okay"
						android:textColor="@color/color_on_secondary"
						android:textSize="@dimen/normal_text_size"
						tools:ignore="TextContrastCheck" />
				</RelativeLayout>
			</LinearLayout>
		</LinearLayout>
	</androidx.cardview.widget.CardView>
</LinearLayout>