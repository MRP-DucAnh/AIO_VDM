<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/button_finish_download_row"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:background="@color/transparent"
	android:clickable="true"
	tools:ignore="UseAppTint, UselessParent">

	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginBottom="@dimen/_5"
		android:orientation="vertical"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_2">

		<RelativeLayout
			android:id="@+id/main_row_container"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:background="@drawable/ic_button_selector_background">

			<androidx.cardview.widget.CardView
				android:id="@+id/thumbnail_container"
				android:layout_width="@dimen/_100"
				android:layout_height="@dimen/_70"
				android:layout_marginStart="@dimen/_5"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_0"
				android:layout_marginBottom="@dimen/_5"
				app:cardBackgroundColor="@color/color_cardview_bg"
				app:cardCornerRadius="@dimen/_5"
				app:cardElevation="@dimen/_0"
				tools:ignore="TextSizeCheck">

				<ImageView
					android:id="@+id/img_media_play_indicator"
					android:layout_width="@dimen/_17"
					android:layout_height="wrap_content"
					android:layout_gravity="center"
					android:adjustViewBounds="true"
					android:elevation="@dimen/_5"
					android:importantForAccessibility="no"
					android:src="@drawable/image_media_play"
					android:tint="@color/color_on_primary"
					android:visibility="visible"
					tools:ignore="ImageContrastCheck" />

				<ImageView
					android:id="@+id/img_file_thumbnail"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_centerVertical="true"
					android:adjustViewBounds="true"
					android:importantForAccessibility="no"
					android:scaleType="centerCrop"
					android:src="@drawable/image_no_thumb_available"
					tools:ignore="ImageContrastCheck" />

				<ImageView
					android:id="@+id/img_site_favicon"
					android:layout_width="@dimen/_20"
					android:layout_height="wrap_content"
					android:layout_gravity="start|top"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:adjustViewBounds="true"
					android:elevation="@dimen/_5"
					android:importantForAccessibility="no"
					android:src="@drawable/ic_image_default_favicon"
					android:visibility="visible"
					tools:ignore="ImageContrastCheck" />

				<LinearLayout
					android:id="@+id/container_media_duration"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_gravity="end"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_5"
					android:background="@drawable/rounded_primary_color"
					android:orientation="vertical"
					android:visibility="visible">

					<TextView
						android:id="@+id/txt_media_duration"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginEnd="@dimen/_5"
						android:fontFamily="@font/font_family_semibold"
						android:text="@string/title_time_representation"
						android:textColor="@color/color_on_primary"
						android:textSize="@dimen/smaller_text_size"
						android:textStyle="normal"
						tools:ignore="TextContrastCheck" />
				</LinearLayout>

				<LinearLayout
					android:id="@+id/container_views_counts"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_gravity="bottom|start"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_5"
					android:background="@drawable/rounded_primary_color"
					android:orientation="vertical"
					android:visibility="visible">

					<TextView
						android:id="@+id/txt_views_count"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginEnd="@dimen/_5"
						android:fontFamily="@font/font_family_semibold"
						android:text="@string/title__"
						android:textColor="@color/color_on_primary"
						android:textSize="@dimen/smaller_text_size"
						android:textStyle="normal"
						tools:ignore="TextContrastCheck" />
				</LinearLayout>
			</androidx.cardview.widget.CardView>

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_centerVertical="true"
				android:layout_marginStart="@dimen/_8"
				android:layout_marginEnd="@dimen/_5"
				android:layout_toEndOf="@id/thumbnail_container"
				android:orientation="vertical">

				<RelativeLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="-2dp"
					tools:ignore="VisualLintBounds">

					<TextView
						android:id="@+id/txt_file_name"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_toStartOf="@id/btn_play_video"
						android:ellipsize="end"
						android:fontFamily="@font/font_family_medium"
						android:gravity="top|left"
						android:maxLines="2"
						android:singleLine="false"
						android:text="@string/text_sample_video_file_name"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size_small"
						tools:ignore="TextSizeCheck,VisualLintBounds" />

					<ImageView
						android:id="@+id/btn_play_video"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_alignParentEnd="true"
						android:layout_centerVertical="true"
						android:layout_marginStart="@dimen/_5"
						android:adjustViewBounds="true"
						android:importantForAccessibility="no"
						android:src="@drawable/ic_button_open_v2"
						android:tint="@color/color_secondary"
						tools:ignore="ImageContrastCheck" />
				</RelativeLayout>

				<RelativeLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="@dimen/_3"
					android:background="@drawable/rounded_surface_color"
					android:orientation="horizontal">

					<TextView
						android:id="@+id/txt_video_metainfo"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_alignParentStart="true"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_2"
						android:layout_marginEnd="@dimen/_5"
						android:layout_marginBottom="@dimen/_2"
						android:layout_toStartOf="@+id/img_trending_indicator"
						android:ellipsize="end"
						android:fontFamily="@font/font_family_regular"
						android:gravity="center_vertical"
						android:singleLine="true"
						android:text="@string/title_sample_featured_vid_metainfo"
						android:textColor="@color/color_text_hint"
						android:textSize="@dimen/small_text_size"
						tools:ignore="TextContrastCheck" />

					<ImageView
						android:id="@+id/img_trending_indicator"
						android:layout_width="@dimen/_15"
						android:layout_height="wrap_content"
						android:layout_alignParentEnd="true"
						android:layout_centerVertical="true"
						android:layout_marginEnd="@dimen/_5"
						android:adjustViewBounds="true"
						android:importantForAccessibility="yes"
						android:src="@drawable/image_button_fire"
						android:visibility="visible"
						tools:ignore="ContentDescription,ImageContrastCheck" />
				</RelativeLayout>
			</LinearLayout>
		</RelativeLayout>
	</androidx.cardview.widget.CardView>
</RelativeLayout>
