<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/transparent"
	android:orientation="vertical"
	tools:ignore="UseCompatTextViewDrawableXml,UseAppTint">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical">

		<androidx.cardview.widget.CardView
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/_5"
			android:layout_marginTop="@dimen/_10"
			android:layout_marginEnd="@dimen/_5"
			android:layout_marginBottom="@dimen/_10"
			android:orientation="vertical"
			app:cardBackgroundColor="@color/color_cardview_bg"
			app:cardCornerRadius="@dimen/_10">

			<RelativeLayout
				android:id="@+id/edit_url_section"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:orientation="vertical">

				<LinearLayout
					android:id="@+id/edit_url_container"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_centerVertical="true"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_5"
					android:layout_toStartOf="@+id/btn_add_download"
					android:background="@drawable/rounded_surface_color"
					android:clickable="true"
					android:orientation="vertical"
					tools:ignore="TouchTargetSizeCheck">

					<EditText
						android:id="@+id/edit_file_url"
						style="@style/style_dialog.message"
						android:layout_margin="@dimen/_8"
						android:background="@color/transparent"
						android:drawableStart="@drawable/ic_button_video"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/font_family_regular"
						android:gravity="center_vertical"
						android:hint="@string/title_search_or_enter_url"
						android:importantForAutofill="no"
						android:inputType="textUri"
						android:maxLines="1"
						android:singleLine="true"
						android:textColor="@color/color_on_surface"
						android:textColorHint="@color/color_text_hint"
						android:textSize="@dimen/normal_text_size"
						tools:ignore="VisualLintTextFieldSize,TextContrastCheck,TouchTargetSizeCheck" />
				</LinearLayout>

				<RelativeLayout
					android:id="@+id/btn_add_download"
					android:layout_width="@dimen/_50"
					android:layout_height="@dimen/_40"
					android:layout_alignParentEnd="true"
					android:layout_centerVertical="true"
					android:layout_marginEnd="@dimen/_5"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck">

					<ImageView
						android:layout_width="@dimen/_30"
						android:layout_height="match_parent"
						android:layout_centerInParent="true"
						android:adjustViewBounds="true"
						android:importantForAccessibility="no"
						android:src="@drawable/ic_button_actionbar_send"
						android:tint="@color/color_secondary"
						tools:ignore="ImageContrastCheck" />
				</RelativeLayout>
			</RelativeLayout>
		</androidx.cardview.widget.CardView>

		<androidx.cardview.widget.CardView
			android:id="@+id/container_favorite_sites"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/_5"
			android:layout_marginTop="@dimen/_0"
			android:layout_marginEnd="@dimen/_5"
			android:layout_marginBottom="@dimen/_10"
			android:orientation="vertical"
			app:cardBackgroundColor="@color/color_cardview_bg"
			app:cardCornerRadius="@dimen/_10">

			<LinearLayout
				android:id="@+id/favorite_site_bookmark_section"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:layout_marginStart="@dimen/_8"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_8"
				android:layout_marginBottom="@dimen/_5"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<androidx.recyclerview.widget.RecyclerView
					android:id="@+id/favicons_recycler_list"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:clipToPadding="false"
					app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
					app:spanCount="4"
					tools:listitem="@layout/frag_home_1_main_1_fav_item_1" />
			</LinearLayout>
		</androidx.cardview.widget.CardView>

		<androidx.cardview.widget.CardView
			android:id="@+id/container_history_bookmark"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/_5"
			android:layout_marginTop="@dimen/_0"
			android:layout_marginEnd="@dimen/_5"
			android:layout_marginBottom="@dimen/_10"
			android:orientation="vertical"
			app:cardBackgroundColor="@color/color_cardview_bg"
			app:cardCornerRadius="@dimen/_10">

			<LinearLayout
				android:id="@+id/history_bookmark_section"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:layout_marginStart="@dimen/_8"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_8"
				android:layout_marginBottom="@dimen/_5"
				android:baselineAligned="false"
				android:orientation="horizontal">

				<RelativeLayout
					android:id="@+id/btn_open_history"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_gravity="center_vertical"
					android:layout_margin="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_centerInParent="true"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_web_history"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:fontFamily="@font/font_family_semibold"
						android:gravity="center_vertical"
						android:text="@string/title_web_history"
						android:textSize="@dimen/normal_text_size" />

					<TextView
						android:id="@+id/txt_web_history_counter"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_alignParentEnd="true"
						android:layout_marginHorizontal="@dimen/_5"
						android:layout_marginTop="@dimen/_1"
						android:background="@drawable/rounded_secondary_color"
						android:fontFamily="@font/font_family_bold"
						android:gravity="center"
						android:includeFontPadding="false"
						android:paddingStart="@dimen/_3"
						android:paddingEnd="@dimen/_3"
						android:text="@string/text_empty_string"
						android:textColor="@color/color_on_secondary"
						android:textSize="@dimen/smallest_text_size"
						tools:ignore="RelativeOverlap" />
				</RelativeLayout>

				<View
					android:layout_width="@dimen/_2"
					android:layout_height="match_parent"
					android:layout_marginHorizontal="@dimen/_5"
					android:layout_marginVertical="@dimen/_2"
					android:alpha=".5"
					android:background="@drawable/rounded_border_color" />

				<RelativeLayout
					android:id="@+id/btn_open_bookmark"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_gravity="center_vertical"
					android:layout_margin="@dimen/_0"
					android:layout_weight="1"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_centerInParent="true"
						android:layout_margin="@dimen/_8"
						android:drawableStart="@drawable/ic_button_save_bookmark"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_secondary"
						android:fontFamily="@font/font_family_semibold"
						android:gravity="center_vertical"
						android:text="@string/title_bookmarks"
						android:textSize="@dimen/normal_text_size" />

					<TextView
						android:id="@+id/txt_web_bookmark_counter"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_alignParentEnd="true"
						android:layout_marginHorizontal="@dimen/_5"
						android:layout_marginTop="@dimen/_1"
						android:background="@drawable/rounded_secondary_color"
						android:fontFamily="@font/font_family_bold"
						android:gravity="center"
						android:includeFontPadding="false"
						android:paddingStart="@dimen/_3"
						android:paddingEnd="@dimen/_3"
						android:text="@string/text_empty_string"
						android:textColor="@color/color_on_secondary"
						android:textSize="@dimen/smallest_text_size"
						tools:ignore="RelativeOverlap" />
				</RelativeLayout>
			</LinearLayout>
		</androidx.cardview.widget.CardView>

		<androidx.cardview.widget.CardView
			android:id="@+id/container_active_downloads"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/_5"
			android:layout_marginTop="@dimen/_0"
			android:layout_marginEnd="@dimen/_5"
			android:layout_marginBottom="@dimen/_10"
			android:orientation="vertical"
			android:visibility="gone"
			app:cardBackgroundColor="@color/color_cardview_bg"
			app:cardCornerRadius="@dimen/_10">

			<RelativeLayout
				android:layout_width="wrap_content"
				android:layout_height="41dp"
				android:layout_gravity="center"
				android:layout_marginStart="@dimen/_8"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_8"
				android:layout_marginBottom="@dimen/_5"
				android:baselineAligned="false">

				<TextView
					android:id="@+id/txt_active_downloads_info"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_centerVertical="true"
					android:layout_marginEnd="@dimen/_5"
					android:layout_toStartOf="@+id/btn_open_active_downloads"
					android:drawableStart="@drawable/ic_button_running"
					android:drawablePadding="@dimen/_5"
					android:drawableTint="@color/color_secondary"
					android:ellipsize="end"
					android:fontFamily="@font/font_family_semibold"
					android:gravity="left|center_vertical"
					android:maxLines="1"
					android:text="@string/title__"
					android:textSize="@dimen/normal_text_size" />

				<RelativeLayout
					android:id="@+id/btn_open_active_downloads"
					android:layout_width="@dimen/_50"
					android:layout_height="@dimen/_40"
					android:layout_alignParentEnd="true"
					android:layout_centerVertical="true"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck">

					<ImageView
						android:layout_width="@dimen/_30"
						android:layout_height="match_parent"
						android:layout_centerInParent="true"
						android:adjustViewBounds="true"
						android:importantForAccessibility="no"
						android:src="@drawable/ic_button_arrow_next"
						android:tint="@color/color_secondary"
						tools:ignore="ImageContrastCheck" />
				</RelativeLayout>
			</RelativeLayout>
		</androidx.cardview.widget.CardView>

		<androidx.cardview.widget.CardView
			android:id="@+id/container_featured_videos"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/_5"
			android:layout_marginTop="@dimen/_0"
			android:layout_marginEnd="@dimen/_5"
			android:layout_marginBottom="@dimen/_10"
			android:orientation="vertical"
			android:visibility="gone"
			app:cardBackgroundColor="@color/color_cardview_bg"
			app:cardCornerRadius="@dimen/_10">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:orientation="vertical">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:background="@color/color_cardview_title_bg"
					android:orientation="vertical">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_margin="@dimen/_10"
						android:fontFamily="@font/font_family_bold"
						android:gravity="center"
						android:text="@string/title_featured_videos"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</LinearLayout>

				<androidx.recyclerview.widget.RecyclerView
					android:id="@+id/featured_videos_recycle_list"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_gravity="center_horizontal"
					android:layout_marginStart="@dimen/_3"
					android:layout_marginTop="@dimen/_3"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_0"
					android:clipToPadding="true"
					android:visibility="visible"
					app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
					app:spanCount="1"
					tools:listitem="@layout/frag_home_1_main_1_feat_vid_item_1" />

				<RelativeLayout
					android:id="@+id/btn_open_trending_videos"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginStart="@dimen/_25"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_25"
					android:layout_marginBottom="@dimen/_8"
					android:background="@drawable/ic_button_selector_secondary"
					android:clickable="true"
					android:elevation="@dimen/_2"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_centerInParent="true"
						android:layout_margin="@dimen/_7"
						android:drawableStart="@drawable/ic_button_videos"
						android:drawableEnd="@drawable/ic_button_arrow_next"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_on_secondary"
						android:fontFamily="@font/font_family_bold"
						android:gravity="center"
						android:text="@string/title_trending_videos"
						android:textColor="@color/color_on_secondary"
						android:textSize="@dimen/normal_text_size"
						tools:ignore="UseCompatTextViewDrawableXml" />
				</RelativeLayout>
			</LinearLayout>
		</androidx.cardview.widget.CardView>

		<androidx.cardview.widget.CardView
			android:id="@+id/container_recent_downloads"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/_5"
			android:layout_marginTop="@dimen/_0"
			android:layout_marginEnd="@dimen/_5"
			android:layout_marginBottom="@dimen/_10"
			android:orientation="vertical"
			android:visibility="gone"
			app:cardBackgroundColor="@color/color_cardview_bg"
			app:cardCornerRadius="@dimen/_10">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:orientation="vertical">

				<RelativeLayout
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:background="@color/color_cardview_title_bg"
					android:orientation="horizontal">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_centerInParent="true"
						android:layout_margin="@dimen/_10"
						android:fontFamily="@font/font_family_bold"
						android:gravity="center"
						android:text="@string/title_recent_downloads"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />

					<RelativeLayout
						android:id="@+id/btn_cardtitle_open_downloads"
						android:layout_width="@dimen/_50"
						android:layout_height="match_parent"
						android:layout_alignParentEnd="true"
						android:layout_centerVertical="true"
						android:layout_marginEnd="@dimen/_5"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck">

						<ImageView
							android:layout_width="@dimen/_30"
							android:layout_height="wrap_content"
							android:layout_centerInParent="true"
							android:adjustViewBounds="true"
							android:importantForAccessibility="no"
							android:src="@drawable/ic_button_video"
							android:tint="@color/color_secondary"
							tools:ignore="ImageContrastCheck" />
					</RelativeLayout>
				</RelativeLayout>

				<androidx.recyclerview.widget.RecyclerView
					android:id="@+id/recent_downloads_recycle_list"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_gravity="center_horizontal"
					android:layout_marginStart="@dimen/_3"
					android:layout_marginTop="@dimen/_3"
					android:layout_marginEnd="@dimen/_3"
					android:layout_marginBottom="@dimen/_5"
					android:clipToPadding="true"
					android:visibility="gone"
					app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
					app:spanCount="3"
					tools:listitem="@layout/frag_home_1_main_1_recent_item_1" />

			</LinearLayout>
		</androidx.cardview.widget.CardView>

		<androidx.cardview.widget.CardView
			android:id="@+id/container_loading_downloads"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/_5"
			android:layout_marginTop="@dimen/_0"
			android:layout_marginEnd="@dimen/_5"
			android:layout_marginBottom="@dimen/_10"
			android:orientation="vertical"
			android:visibility="visible"
			app:cardBackgroundColor="@color/color_cardview_bg"
			app:cardCornerRadius="@dimen/_10">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical">

				<com.airbnb.lottie.LottieAnimationView
					android:id="@+id/img_progress_circle"
					android:layout_width="@dimen/_120"
					android:layout_height="wrap_content"
					android:layout_gravity="center_vertical|center_horizontal"
					android:layout_marginTop="-20dp"
					android:layout_marginBottom="-50dp"
					android:adjustViewBounds="true"
					android:hardwareAccelerated="true"
					android:importantForAccessibility="no"
					android:layerType="hardware"
					android:visibility="visible"
					app:lottie_autoPlay="true"
					app:lottie_enableMergePathsForKitKatAndAbove="true"
					app:lottie_loop="true"
					app:lottie_rawRes="@raw/animation_circle_loading"
					tools:ignore="ImageContrastCheck,VisualLintBounds" />

				<TextView
					android:id="@+id/txt_progress_info"
					style="@style/style_dialog.message"
					android:layout_marginStart="@dimen/_10"
					android:layout_marginTop="@dimen/_8"
					android:layout_marginEnd="@dimen/_10"
					android:layout_marginBottom="@dimen/_10"
					android:autoLink="web"
					android:fontFamily="@font/font_family_semibold"
					android:text="@string/title_loading_downloads_data"
					android:textSize="@dimen/message_text_size" />
			</LinearLayout>
		</androidx.cardview.widget.CardView>

		<androidx.cardview.widget.CardView
			android:id="@+id/container_empty_downloads"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/_5"
			android:layout_marginTop="@dimen/_0"
			android:layout_marginEnd="@dimen/_5"
			android:layout_marginBottom="@dimen/_10"
			android:orientation="vertical"
			android:visibility="gone"
			app:cardBackgroundColor="@color/color_cardview_bg"
			app:cardCornerRadius="@dimen/_10">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:orientation="vertical">

				<com.airbnb.lottie.LottieAnimationView
					android:id="@+id/img_empty_downloads"
					android:layout_width="@dimen/_150"
					android:layout_height="wrap_content"
					android:layout_gravity="center"
					android:layout_marginTop="@dimen/_5"
					android:adjustViewBounds="true"
					android:hardwareAccelerated="true"
					android:importantForAccessibility="no"
					android:layerType="hardware"
					android:minHeight="@dimen/_50"
					app:lottie_autoPlay="true"
					app:lottie_enableMergePathsForKitKatAndAbove="true"
					app:lottie_loop="true"
					tools:ignore="ImageContrastCheck" />

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_gravity="center_horizontal|center_vertical"
					android:layout_marginStart="@dimen/_25"
					android:layout_marginEnd="@dimen/_25"
					android:layout_marginBottom="@dimen/_8"
					android:fontFamily="@font/font_family_regular"
					android:gravity="center"
					android:text="@string/title_you_dont_have_any_downloads"
					android:textColor="@color/color_text_primary"
					android:textSize="@dimen/message_text_size" />

				<RelativeLayout
					android:id="@+id/btn_how_to_download"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginStart="@dimen/_10"
					android:layout_marginTop="@dimen/_0"
					android:layout_marginEnd="@dimen/_10"
					android:layout_marginBottom="@dimen/_10"
					android:background="@drawable/ic_button_selector_secondary"
					android:clickable="true"
					android:elevation="@dimen/_2"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_centerInParent="true"
						android:layout_margin="@dimen/_7"
						android:drawableStart="@drawable/ic_button_question"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_on_secondary"
						android:fontFamily="@font/font_family_semibold"
						android:gravity="center"
						android:text="@string/title_how_to_download"
						android:textColor="@color/color_on_secondary"
						android:textSize="@dimen/normal_text_size" />
				</RelativeLayout>
			</LinearLayout>
		</androidx.cardview.widget.CardView>
	</LinearLayout>
</androidx.core.widget.NestedScrollView>