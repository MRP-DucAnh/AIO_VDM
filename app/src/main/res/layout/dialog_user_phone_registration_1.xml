<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/style_dialog"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	tools:ignore="UseAppTint,UseCompatTextViewDrawableXml"
	>
	
	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginHorizontal="@dimen/_5"
		android:layout_marginVertical="@dimen/_10"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_5"
		>
		
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			>
			
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="@color/color_cardview_title_bg"
				android:orientation="vertical"
				android:visibility="visible"
				>
				
				<TextView
					android:id="@+id/txt_dialog_title"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_gravity="center_horizontal"
					android:layout_margin="@dimen/_10"
					android:ellipsize="end"
					android:fontFamily="@font/font_family_bold"
					android:maxLines="1"
					android:text="@string/title_login_with_phone_number"
					android:textColor="@color/color_text_primary"
					android:textSize="@dimen/normal_text_size"
					/>
			</LinearLayout>
			
			<ScrollView
				android:layout_width="match_parent"
				android:layout_height="0dp"
				android:layout_marginHorizontal="@dimen/_10"
				android:layout_weight="1"
				>
				
				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					>
					
					<LinearLayout
						android:id="@+id/container_edit_field_phone_number"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_0"
						android:layout_marginTop="@dimen/_10"
						android:layout_marginEnd="@dimen/_0"
						android:layout_marginBottom="@dimen/_8"
						android:background="@drawable/rounded_surface_color"
						android:clipChildren="false"
						android:clipToPadding="false"
						android:orientation="vertical"
						>
						
						<EditText
							android:id="@+id/edit_field_phone_number"
							style="@style/style_dialog.message"
							android:layout_margin="@dimen/_8"
							android:background="@color/transparent"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:drawableStart="@drawable/ic_button_phone_number"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:gravity="center_vertical"
							android:hint="@string/title_enter_your_phone_number"
							android:importantForAutofill="no"
							android:inputType="phone"
							android:maxLines="1"
							android:singleLine="true"
							android:textColor="@color/color_on_surface"
							android:textColorHint="@color/color_text_hint"
							android:textSize="@dimen/normal_text_size"
							android:textStyle="normal"
							tools:ignore="TextContrastCheck,TouchTargetSizeCheck,VisualLintTextFieldSize"
							/>
					</LinearLayout>
					
					<RelativeLayout
						android:id="@+id/container_edit_field_password"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_0"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_0"
						android:layout_marginBottom="@dimen/_3"
						android:background="@drawable/rounded_surface_color"
						android:clipChildren="false"
						android:clipToPadding="false"
						android:orientation="horizontal"
						android:visibility="visible"
						>
						
						<EditText
							android:id="@+id/edit_field_password"
							style="@style/style_dialog.message"
							android:layout_margin="@dimen/_8"
							android:background="@color/transparent"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:drawableStart="@drawable/ic_button_password"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:gravity="center_vertical"
							android:hint="@string/title_enter_your_secret_otp"
							android:importantForAutofill="no"
							android:inputType="textPassword"
							android:maxLines="1"
							android:singleLine="true"
							android:textColor="@color/color_on_surface"
							android:textColorHint="@color/color_text_hint"
							android:textSize="@dimen/normal_text_size"
							android:textStyle="normal"
							tools:ignore="TextContrastCheck,TextFields,TouchTargetSizeCheck,VisualLintTextFieldSize"
							/>
					</RelativeLayout>
					
					<TextView
						android:id="@+id/txt_resend_opt_timer_info"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_gravity="center_horizontal|center_vertical"
						android:layout_marginTop="@dimen/_5"
						android:layout_marginBottom="@dimen/_8"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:ellipsize="end"
						android:fontFamily="@font/font_family_medium"
						android:gravity="center_vertical|center_horizontal"
						android:maxLines="1"
						android:paddingHorizontal="@dimen/_10"
						android:text="@string/title_you_can_resend_otp_after"
						android:textColor="@color/color_secondary"
						android:textSize="@dimen/message_text_size"
						android:visibility="gone"
						tools:ignore="TouchTargetSizeCheck"
						/>
					
					<RelativeLayout
						android:id="@+id/btn_register_account"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_25"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_25"
						android:layout_marginBottom="@dimen/_5"
						android:background="@drawable/ic_button_selector_secondary"
						android:clickable="true"
						android:elevation="@dimen/_2"
						tools:ignore="TouchTargetSizeCheck"
						>
						
						<TextView
							android:id="@+id/txt_register_account"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_centerInParent="true"
							android:layout_margin="@dimen/_7"
							android:drawableEnd="@drawable/ic_button_actionbar_send"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_on_secondary"
							android:fontFamily="@font/font_family_semibold"
							android:gravity="center"
							android:text="@string/title_send_verification_code"
							android:textColor="@color/color_on_secondary"
							android:textSize="@dimen/normal_text_size"
							tools:ignore="UseCompatTextViewDrawableXml"
							/>
					</RelativeLayout>
					
					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_gravity="center_horizontal"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_2"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_8"
						android:fontFamily="@font/font_family_lightitalic"
						android:text="@string/title_registering_account_is_free_safe"
						android:textColor="@color/color_text_secondary"
						android:textSize="@dimen/small_text_size_x2"
						/>
				
				</LinearLayout>
			</ScrollView>
		</LinearLayout>
	</androidx.cardview.widget.CardView>
</LinearLayout>