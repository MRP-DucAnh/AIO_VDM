<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/style_dialog"
	android:layout_width="wrap_content"
	android:layout_height="wrap_content"
	tools:ignore="UseAppTint,UseCompatTextViewDrawableXml">

	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginStart="@dimen/_5"
		android:layout_marginTop="@dimen/_10"
		android:layout_marginEnd="@dimen/_5"
		android:layout_marginBottom="@dimen/_10"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_2">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="@dimen/_35"
				android:background="@color/color_cardview_title_bg"
				android:orientation="horizontal"
				android:visibility="visible"
				tools:ignore="TextSizeCheck">

				<TextView
					style="@style/style_dialog.title"
					android:layout_gravity="center"
					android:fontFamily="@font/font_family_bold"
					android:text="@string/title_media_options"
					android:textColor="@color/color_text_primary"
					android:textSize="@dimen/normal_text_size" />
			</LinearLayout>

			<ScrollView
				android:layout_width="match_parent"
				android:layout_height="wrap_content">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">

					<LinearLayout
						android:id="@+id/btn_delete_file"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_10"
						android:layout_marginEnd="@dimen/_10"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_delete_v2"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_delete_from_disk"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_convert_to_audio"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginHorizontal="@dimen/_10"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_sound"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_convert_to_audio"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_open_in_another"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginHorizontal="@dimen/_10"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_player"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_open_externally"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_discover_video"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginHorizontal="@dimen/_10"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						android:visibility="visible"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_open_v2"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_open_video_site"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_private_videos"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginHorizontal="@dimen/_10"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						android:visibility="visible"
						tools:ignore="TouchTargetSizeCheck">

						<CheckBox
							android:id="@+id/checkbox_private_videos"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_margin="@dimen/_8"
							android:background="@drawable/ic_button_negative_selector"
							android:button="@null"
							android:clickable="false"
							android:drawableStart="@drawable/ic_button_radio_selector"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:ellipsize="end"
							android:fontFamily="@font/font_family_regular"
							android:gravity="center_vertical"
							android:maxLines="1"
							android:text="@string/title_private_videos"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size"
							tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_snapshot"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginHorizontal="@dimen/_10"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						android:visibility="visible"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_camera_shutter"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_frame_snapshot"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_share_media"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginHorizontal="@dimen/_10"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_share_v1"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_share_media_file"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_media_info"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginHorizontal="@dimen/_10"
						android:layout_marginBottom="@dimen/_10"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_information"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_file_information"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

				</LinearLayout>
			</ScrollView>
		</LinearLayout>
	</androidx.cardview.widget.CardView>
</LinearLayout>