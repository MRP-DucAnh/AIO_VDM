<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/custom_toast_layout"
	android:layout_width="wrap_content"
	android:layout_height="wrap_content"
	android:layout_marginStart="@dimen/_10"
	android:layout_marginEnd="@dimen/_10"
	android:layout_marginLeft="@dimen/_10"
	android:layout_marginRight="@dimen/_10"
	android:layout_marginTop="@dimen/_10"
	android:layout_marginBottom="@dimen/_10"
	android:paddingStart="@dimen/_0"
	android:paddingEnd="@dimen/_0"
	android:paddingLeft="@dimen/_0"
	android:paddingRight="@dimen/_0"
	android:paddingTop="@dimen/_0"
	android:paddingBottom="@dimen/_0"
	app:cardBackgroundColor="@color/color_toast_view_bg"
	app:cardCornerRadius="@dimen/_10"
	app:cardElevation="@dimen/_5">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:orientation="horizontal"
		android:layout_marginStart="@dimen/_0"
		android:layout_marginEnd="@dimen/_0"
		android:layout_marginLeft="@dimen/_0"
		android:layout_marginRight="@dimen/_0"
		android:layout_marginTop="@dimen/_0"
		android:layout_marginBottom="@dimen/_0"
		android:paddingStart="@dimen/_0"
		android:paddingEnd="@dimen/_0"
		android:paddingLeft="@dimen/_0"
		android:paddingRight="@dimen/_0"
		android:paddingTop="@dimen/_0"
		android:paddingBottom="@dimen/_0">

		<de.hdodenhof.circleimageview.CircleImageView
			android:id="@+id/img_toast_app_icon"
			android:layout_width="@dimen/_30"
			android:layout_height="@dimen/_30"
			android:layout_gravity="center_vertical"
			android:layout_marginStart="@dimen/_10"
			android:layout_marginLeft="@dimen/_10"
			android:layout_marginTop="@dimen/_5"
			android:layout_marginEnd="@dimen/_0"
			android:layout_marginRight="@dimen/_0"
			android:layout_marginBottom="@dimen/_5"
			android:paddingStart="@dimen/_0"
			android:paddingEnd="@dimen/_0"
			android:paddingLeft="@dimen/_0"
			android:paddingRight="@dimen/_0"
			android:paddingTop="@dimen/_0"
			android:paddingBottom="@dimen/_0"
			android:elevation="@dimen/_1"
			android:importantForAccessibility="no"
			android:src="@mipmap/ic_launcher_v3" />

		<TextView
			android:id="@+id/txt_toast_message"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_gravity="center_vertical"
			android:layout_marginStart="@dimen/_10"
			android:layout_marginLeft="@dimen/_10"
			android:layout_marginTop="@dimen/_5"
			android:layout_marginEnd="@dimen/_10"
			android:layout_marginRight="@dimen/_10"
			android:layout_marginBottom="@dimen/_5"
			android:paddingStart="@dimen/_0"
			android:paddingEnd="@dimen/_0"
			android:paddingLeft="@dimen/_0"
			android:paddingRight="@dimen/_0"
			android:paddingTop="@dimen/_0"
			android:paddingBottom="@dimen/_0"
			android:fontFamily="@font/font_family_medium"
			android:gravity="center_vertical"
			android:text="@string/title_100_percentage"
			android:textColor="@color/color_text_primary"
			android:textSize="@dimen/message_text_size" />
	</LinearLayout>

</androidx.cardview.widget.CardView>