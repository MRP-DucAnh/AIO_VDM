							android:button="@null"
							android:clickable="false"
							android:drawableStart="@drawable/ic_button_radio_selector"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:ellipsize="end"
							android:fontFamily="@font/font_family_regular"
							android:gravity="center_vertical"
							android:maxLines="1"
							android:text="@string/title_1_5_faster"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size"
							tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/bnt_playback_speed_1_75x"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginHorizontal="@dimen/_10"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						android:visibility="visible"
						tools:ignore="TouchTargetSizeCheck">

						<CheckBox
							android:id="@+id/checkbox_playback_speed_1_75x"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_margin="@dimen/_8"
							android:background="@drawable/ic_button_negative_selector"
							android:button="@null"
							android:clickable="false"
							android:drawableStart="@drawable/ic_button_radio_selector"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:ellipsize="end"
							android:fontFamily="@font/font_family_regular"
							android:gravity="center_vertical"
							android:maxLines="1"
							android:text="@string/title_1_75_fastest"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size"
							tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/bnt_playback_speed_2x"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginHorizontal="@dimen/_10"
						android:layout_marginBottom="@dimen/_10"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						android:visibility="visible"
						tools:ignore="TouchTargetSizeCheck">

						<CheckBox
							android:id="@+id/check_playback_speed_2x"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_margin="@dimen/_8"
							android:background="@drawable/ic_button_negative_selector"
							android:button="@null"
							android:clickable="false"
							android:drawableStart="@drawable/ic_button_radio_selector"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:ellipsize="end"
							android:fontFamily="@font/font_family_regular"
							android:gravity="center_vertical"
							android:maxLines="1"
							android:text="@string/title_2_lighting"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size"
							tools:ignore="TouchTargetSizeCheck,VisualLintButtonSize" />
					</LinearLayout>

				</LinearLayout>
			</ScrollView>
