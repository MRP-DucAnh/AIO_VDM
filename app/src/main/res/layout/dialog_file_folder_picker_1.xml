<?xml version="1.0" encoding="utf-8"?>
<!-- =========================================================================
     Content Region Selection Dialog Layout
     Provides a user interface for selecting preferred content regions/locations
     with a list-based selection approach and application restart requirement notice.

     This dialog is used when users need to choose their geographic content preference
     (e.g., country, region) which may affect available content, language defaults,
     or service availability. The selection requires app restart to fully apply
     regional-specific configurations and content filtering.

     Layout Structure:
     - CardView container with elevated Material Design styling
     - Optional title section for dialog context (currently visible)
     - Scrollable ListView for region/location option presentation
     - Prominent apply button with confirmation icon
     - Proper spacing and touch target sizing for accessibility
     ========================================================================= -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/style_dialog"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	tools:ignore="UseAppTint,UseCompatTextViewDrawableXml,VisualLintBounds">

	<!-- ============================================================
	     DIALOG CARD CONTAINER
	     Material Design CardView providing visual elevation, rounded
	     corners, and consistent dialog styling. Uses moderate elevation
	     for prominence while maintaining accessibility standards.
	     Margin spacing ensures proper visual separation from screen edges.
	     ============================================================ -->
	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginStart="@dimen/_5"
		android:layout_marginTop="@dimen/_10"
		android:layout_marginEnd="@dimen/_5"
		android:layout_marginBottom="@dimen/_10"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_5">

		<!-- ======================================================
		     VERTICAL CONTENT CONTAINER
		     Organizes dialog elements in sequential vertical order:
		     title header, content list, and action button.
		     Uses wrap_content height to accommodate variable list sizes.
		     ====================================================== -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<!-- ==================================================
			     DIALOG TITLE SECTION
			     Currently visible header providing context about
			     the dialog's purpose. Uses colored background
			     for visual separation from content area.
			     Can be hidden if title context is provided elsewhere.
			     ================================================== -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="@color/color_cardview_title_bg"
				android:orientation="vertical"
				android:visibility="visible">

				<!-- Dialog title text with proper typography and truncation -->
				<TextView
					android:id="@+id/txt_dialog_title"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_margin="@dimen/_10"
					android:ellipsize="end"
					android:fontFamily="@font/application_font_family"
					android:gravity="center"
					android:maxLines="1"
					android:text="@string/title_file_folder_picker"
					android:textColor="@color/color_text_primary"
					android:textFontWeight="600"
					android:textSize="@dimen/normal_text_size" />
			</LinearLayout>

			<!-- ==================================================
			     CONTENT REGION SELECTION LISTVIEW
			     Scrollable list container for displaying available
			     content regions/locations. Uses layout_weight to
			     fill available vertical space between title and button.

			     Features:
			     - Dynamic height allocation based on content
			     - Transparent divider for clean visual separation
			     - Optimized for potentially long region lists
			     - Built-in scrolling for overflow handling

			     Expected data: List of regions/countries with
			     selection states (radio buttons or checkmarks)
			     ================================================== -->
			<ListView
				android:id="@+id/container_download_tasks_finished"
				android:layout_width="match_parent"
				android:layout_height="0dp"
				android:layout_marginStart="@dimen/_0"
				android:layout_marginTop="@dimen/_0"
				android:layout_marginEnd="@dimen/_0"
				android:layout_marginBottom="@dimen/_0"
				android:layout_weight="1"
				android:divider="@color/transparent"
				android:visibility="visible" />

			<!-- ==================================================
			     APPLY SELECTION BUTTON CONTAINER
			     Primary action button for confirming region selection
			     and applying changes. Uses secondary color scheme
			     for visual prominence and elevation for hierarchy.

			     Behavior: When clicked, applies the selected region
			     and may show restart requirement notification to
			     user for changes to take full effect.
			     ================================================== -->
			<RelativeLayout
				android:id="@+id/btn_dialog_positive_container"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_10"
				android:layout_marginBottom="@dimen/_8"
				android:background="@drawable/ic_button_selector_secondary"
				android:clickable="true"
				android:elevation="@dimen/_2"
				tools:ignore="TouchTargetSizeCheck">

				<!-- Apply button with confirmation icon and centered text -->
				<TextView
					android:id="@+id/btn_dialog_positive"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_centerInParent="true"
					android:layout_margin="@dimen/_7"
					android:drawableStart="@drawable/ic_okay_done"
					android:drawablePadding="@dimen/_5"
					android:drawableTint="@color/color_on_secondary"
					android:fontFamily="@font/application_font_family"
					android:gravity="center"
					android:text="@string/title_select"
					android:textColor="@color/color_on_secondary"
					android:textFontWeight="600"
					android:textSize="@dimen/normal_text_size" />
			</RelativeLayout>
		</LinearLayout>
	</androidx.cardview.widget.CardView>
</LinearLayout>