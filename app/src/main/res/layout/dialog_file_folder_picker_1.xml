<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/style_dialog"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	tools:ignore="UseAppTint,UseCompatTextViewDrawableXml,VisualLintBounds">

	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginStart="@dimen/_5"
		android:layout_marginTop="@dimen/_10"
		android:layout_marginEnd="@dimen/_5"
		android:layout_marginBottom="@dimen/_10"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_5">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="@color/color_cardview_title_bg"
				android:orientation="vertical"
				android:visibility="visible">

				<TextView
					android:id="@+id/txt_dialog_title"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_margin="@dimen/_10"
					android:ellipsize="end"
					android:fontFamily="@font/font_family_bold"
					android:gravity="center"
					android:maxLines="1"
					android:text="@string/title_file_folder_picker"
					android:textColor="@color/color_text_primary"
					android:textSize="@dimen/normal_text_size" />
			</LinearLayout>

			<HorizontalScrollView
				android:id="@+id/container_breadcrumb_scroll"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginHorizontal="@dimen/_10"
				android:layout_marginTop="@dimen/_5"
				android:background="@drawable/rounded_border_color"
				android:paddingHorizontal="@dimen/_5"
				android:scrollbars="none"
				tools:ignore="SpeakableTextPresentCheck">

				<LinearLayout
					android:id="@+id/container_breadcrumb"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_gravity="center_vertical"
					android:layout_marginHorizontal="@dimen/_5"
					android:layout_marginVertical="@dimen/_5"
					android:orientation="horizontal" />
			</HorizontalScrollView>

			<TextView
				android:id="@+id/btn_go_to_previous_dir"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginHorizontal="@dimen/_10"
				android:layout_marginVertical="@dimen/_5"
				android:background="@drawable/ic_button_negative_selector"
				android:clickable="true"
				android:drawableStart="@drawable/ic_button_arrow_back"
				android:drawablePadding="@dimen/_5"
				android:drawableTint="@color/color_secondary"
				android:fontFamily="@font/font_family_semibold"
				android:gravity="center_vertical"
				android:padding="@dimen/_3"
				android:text="@string/go_back_previous_path"
				tools:ignore="TouchTargetSizeCheck" />

			<ListView
				android:id="@+id/list_of_files_folders"
				android:layout_width="match_parent"
				android:layout_height="0dp"
				android:layout_marginHorizontal="@dimen/_5"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginBottom="@dimen/_5"
				android:layout_weight="1"
				android:divider="@color/transparent"
				android:dividerHeight="@dimen/_5"
				android:visibility="visible" />

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/_5"
				android:baselineAligned="true"
				android:orientation="horizontal">

				<RelativeLayout
					android:id="@+id/button_dialog_negative_container"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="@dimen/_10"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_10"
					android:layout_marginBottom="@dimen/_5"
					android:layout_weight="0.4"
					android:background="@drawable/ic_button_negative_selector"
					android:clickable="true"
					android:visibility="gone"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:id="@+id/button_dialog_negative"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_centerInParent="true"
						android:layout_margin="@dimen/_7"
						android:drawableStart="@drawable/ic_button_cancel"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_text_primary"
						android:ellipsize="end"
						android:fontFamily="@font/font_family_semibold"
						android:gravity="center"
						android:maxLines="1"
						android:text="@string/title_cancel"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/normal_text_size" />
				</RelativeLayout>

				<RelativeLayout
					android:id="@+id/btn_dialog_positive_container"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="@dimen/_10"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_10"
					android:layout_marginBottom="@dimen/_5"
					android:layout_weight="0.6"
					android:background="@drawable/ic_button_selector_secondary"
					android:clickable="true"
					android:elevation="@dimen/_2"
					tools:ignore="TouchTargetSizeCheck">

					<TextView
						android:id="@+id/btn_dialog_positive"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_centerInParent="true"
						android:layout_margin="@dimen/_7"
						android:drawableStart="@drawable/ic_button_checked_circle"
						android:drawablePadding="@dimen/_5"
						android:drawableTint="@color/color_on_secondary"
						android:ellipsize="end"
						android:fontFamily="@font/font_family_semibold"
						android:gravity="center"
						android:maxLines="1"
						android:text="@string/title_select_folder"
						android:textColor="@color/color_on_secondary"
						android:textSize="@dimen/normal_text_size"
						tools:ignore="TextContrastCheck" />
				</RelativeLayout>
			</LinearLayout>
		</LinearLayout>
	</androidx.cardview.widget.CardView>
</LinearLayout>