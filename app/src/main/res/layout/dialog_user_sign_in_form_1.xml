<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/style_dialog"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	tools:ignore="UseAppTint,UseCompatTextViewDrawableXml"
	>
	
	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginHorizontal="@dimen/_5"
		android:layout_marginVertical="@dimen/_10"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_5"
		>
		
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			>
			
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="@color/color_cardview_title_bg"
				android:orientation="vertical"
				android:visibility="visible"
				>
				
				<TextView
					android:id="@+id/txt_dialog_title"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_margin="@dimen/_10"
					android:ellipsize="end"
					android:fontFamily="@font/font_family_bold"
					android:gravity="center"
					android:maxLines="1"
					android:text="@string/title_sign_in_register"
					android:textColor="@color/color_text_primary"
					android:textSize="@dimen/normal_text_size"
					/>
			</LinearLayout>
			
			<ScrollView
				android:layout_width="match_parent"
				android:layout_height="0dp"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_8"
				android:layout_marginEnd="@dimen/_10"
				android:layout_marginBottom="@dimen/_8"
				android:layout_weight="1"
				>
				
				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					>
					
					<LinearLayout
						android:id="@+id/container_edit_field_name"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_0"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_0"
						android:layout_marginBottom="@dimen/_8"
						android:background="@drawable/rounded_surface_color"
						android:clipChildren="false"
						android:clipToPadding="false"
						android:orientation="vertical"
						android:visibility="gone"
						>
						
						<EditText
							android:id="@+id/edit_field_name"
							style="@style/style_dialog.message"
							android:layout_margin="@dimen/_8"
							android:background="@color/transparent"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:drawableStart="@drawable/ic_button_user_name"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:gravity="center_vertical"
							android:hint="@string/title_your_full_name"
							android:importantForAutofill="no"
							android:inputType="textUri"
							android:maxLines="1"
							android:singleLine="true"
							android:textColor="@color/color_on_surface"
							android:textColorHint="@color/color_text_hint"
							android:textSize="@dimen/normal_text_size"
							android:textStyle="normal"
							tools:ignore="TextContrastCheck,TouchTargetSizeCheck,VisualLintTextFieldSize"
							/>
					</LinearLayout>
					
					<LinearLayout
						android:id="@+id/container_edit_field_email"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_0"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_0"
						android:layout_marginBottom="@dimen/_8"
						android:background="@drawable/rounded_surface_color"
						android:clipChildren="false"
						android:clipToPadding="false"
						android:orientation="vertical"
						>
						
						<EditText
							android:id="@+id/edit_field_email"
							style="@style/style_dialog.message"
							android:layout_margin="@dimen/_8"
							android:background="@color/transparent"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:drawableStart="@drawable/ic_button_email"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:gravity="center_vertical"
							android:hint="@string/title_enter_your_email_address_here"
							android:importantForAutofill="no"
							android:inputType="textEmailAddress"
							android:maxLines="1"
							android:singleLine="true"
							android:textColor="@color/color_on_surface"
							android:textColorHint="@color/color_text_hint"
							android:textSize="@dimen/normal_text_size"
							android:textStyle="normal"
							tools:ignore="TextContrastCheck,TouchTargetSizeCheck,VisualLintTextFieldSize"
							/>
					</LinearLayout>
					
					<RelativeLayout
						android:id="@+id/container_edit_field_password"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_0"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_0"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/rounded_surface_color"
						android:clipChildren="false"
						android:clipToPadding="false"
						android:orientation="horizontal"
						>
						
						<EditText
							android:id="@+id/edit_field_password"
							style="@style/style_dialog.message"
							android:layout_margin="@dimen/_8"
							android:layout_toStartOf="@+id/btn_toggle_password_visibility"
							android:background="@color/transparent"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:drawableStart="@drawable/ic_button_password"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:gravity="center_vertical"
							android:hint="@string/title_enter_your_secret_password"
							android:importantForAutofill="no"
							android:inputType="textPassword"
							android:maxLines="1"
							android:singleLine="true"
							android:textColor="@color/color_on_surface"
							android:textColorHint="@color/color_text_hint"
							android:textSize="@dimen/normal_text_size"
							android:textStyle="normal"
							tools:ignore="TextContrastCheck,TextFields,TouchTargetSizeCheck,VisualLintTextFieldSize"
							/>
						
						<ImageView
							android:id="@+id/btn_toggle_password_visibility"
							android:layout_width="wrap_content"
							android:layout_height="match_parent"
							android:layout_alignParentEnd="true"
							android:layout_centerVertical="true"
							android:adjustViewBounds="true"
							android:background="@drawable/ic_button_negative_selector"
							android:clickable="true"
							android:importantForAccessibility="no"
							android:paddingStart="@dimen/_5"
							android:paddingEnd="@dimen/_5"
							android:src="@drawable/ic_button_hide"
							android:tint="@color/color_secondary"
							tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck,ImageContrastCheck"
							/>
					</RelativeLayout>
					
					<TextView
						android:id="@+id/btn_forget_user_password"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_gravity="end"
						android:layout_marginStart="@dimen/_8"
						android:layout_marginTop="@dimen/_5"
						android:layout_marginEnd="@dimen/_8"
						android:layout_marginBottom="@dimen/_8"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:ellipsize="end"
						android:fontFamily="@font/font_family_semibold"
						android:gravity="center_vertical|end"
						android:maxLines="1"
						android:paddingEnd="@dimen/_10"
						android:text="@string/title_forget_password_question"
						android:textColor="@color/color_secondary"
						android:textSize="@dimen/message_text_size"
						tools:ignore="TouchTargetSizeCheck"
						/>
					
					<RelativeLayout
						android:id="@+id/btn_sign_in"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_25"
						android:layout_marginTop="@dimen/_5"
						android:layout_marginEnd="@dimen/_25"
						android:layout_marginBottom="@dimen/_10"
						android:background="@drawable/ic_button_selector_secondary"
						android:clickable="true"
						android:elevation="@dimen/_2"
						tools:ignore="TouchTargetSizeCheck"
						>
						
						<TextView
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_centerInParent="true"
							android:layout_margin="@dimen/_7"
							android:drawableEnd="@drawable/ic_button_arrow_next"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_on_secondary"
							android:fontFamily="@font/font_family_semibold"
							android:gravity="center"
							android:text="@string/title_sign_in_now"
							android:textColor="@color/color_on_secondary"
							android:textSize="@dimen/normal_text_size"
							tools:ignore="UseCompatTextViewDrawableXml"
							/>
					</RelativeLayout>
					
					<TextView
						android:id="@+id/btn_create_new_account"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_gravity="center"
						android:layout_marginStart="@dimen/_8"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_8"
						android:layout_marginBottom="@dimen/_8"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:ellipsize="end"
						android:fontFamily="@font/font_family_bold"
						android:gravity="center_vertical|end"
						android:maxLines="1"
						android:paddingEnd="@dimen/_10"
						android:text="@string/title_create_new_account"
						android:textColor="@color/color_secondary"
						android:textSize="@dimen/message_text_size"
						tools:ignore="TouchTargetSizeCheck"
						/>
				</LinearLayout>
			</ScrollView>
		</LinearLayout>
	</androidx.cardview.widget.CardView>
</LinearLayout>