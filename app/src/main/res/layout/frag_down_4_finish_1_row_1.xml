<?xml version="1.0" encoding="utf-8"?>
<!-- =========================================================================
     Finished Download Item Layout
     This layout defines a single row item for completed downloads in a list.
     Displays file thumbnail, metadata, and interactive elements for file
     management. Uses CardView for material design with proper elevation
     and rounded corners.
     ========================================================================= -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/button_finish_download_row"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:background="@color/transparent"
	android:clickable="true"
	tools:ignore="UseAppTint, UselessParent">

	<!-- ==============================================
		 MAIN CARD CONTAINER
		 Provides material design card with elevation,
		 rounded corners, and consistent margins.
		 Serves as the visual container for all item
		 content with proper shadow and background.
		 ============================================== -->
	<androidx.cardview.widget.CardView
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginStart="@dimen/_10"
		android:layout_marginTop="@dimen/_3"
		android:layout_marginEnd="@dimen/_10"
		android:layout_marginBottom="@dimen/_5"
		android:orientation="vertical"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10">

		<!-- ==============================================
			 MAIN CONTENT CONTAINER
			 RelativeLayout that holds all visual elements
			 of the download item. Uses selector background
			 for pressed state feedback.
			 ============================================== -->
		<RelativeLayout
			android:id="@+id/main_row_container"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:background="@drawable/ic_button_selector_background">

			<!-- ==============================================
				 THUMBNAIL CONTAINER CARD
				 CardView wrapper for the file thumbnail image
				 with consistent corner radius and background.
				 Provides visual separation for the thumbnail
				 from other content.
				 ============================================== -->
			<androidx.cardview.widget.CardView
				android:id="@+id/container_img_thumbnail"
				android:layout_width="@dimen/_90"
				android:layout_height="@dimen/_57"
				android:layout_marginStart="@dimen/_5"
				android:layout_marginTop="@dimen/_5"
				android:layout_marginEnd="@dimen/_5"
				android:layout_marginBottom="@dimen/_5"
				app:cardBackgroundColor="@color/color_cardview_bg"
				app:cardCornerRadius="@dimen/_5">

				<!-- ==============================================
					 FILE THUMBNAIL IMAGE
					 Primary thumbnail display for the downloaded
					 file. Uses centerCrop scaling to fill container
					 while maintaining aspect ratio. Shows fallback
					 image when no thumbnail is available.
					 ============================================== -->
				<ImageView
					android:id="@+id/img_file_thumbnail"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_centerVertical="true"
					android:adjustViewBounds="true"
					android:importantForAccessibility="no"
					android:scaleType="centerCrop"
					android:src="@drawable/image_no_thumb_available"
					tools:ignore="ImageContrastCheck" />

				<!-- ==============================================
					 PLAY INDICATOR OVERLAY
					 Circular play button icon that appears over
					 media files (audio/video). Hidden by default
					 and shown only for playable media types.
					 Uses elevation to appear above thumbnail.
					 ============================================== -->
				<ImageView
					android:id="@+id/img_media_play_indicator"
					android:layout_width="@dimen/_20"
					android:layout_height="wrap_content"
					android:layout_gravity="center"
					android:adjustViewBounds="true"
					android:elevation="@dimen/_5"
					android:importantForAccessibility="no"
					android:src="@drawable/image_media_play"
					android:tint="@color/color_on_primary"
					android:visibility="gone"
					tools:ignore="ImageContrastCheck" />

				<!-- ==============================================
					 SITE FAVICON INDICATOR
					 Small icon representing the source website
					 where the file was downloaded from. Positioned
					 in top-start corner. Hidden when no favicon
					 data is available.
					 ============================================== -->
				<ImageView
					android:id="@+id/img_site_favicon"
					android:layout_width="@dimen/_20"
					android:layout_height="wrap_content"
					android:layout_gravity="start|top"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:adjustViewBounds="true"
					android:elevation="@dimen/_5"
					android:importantForAccessibility="no"
					android:visibility="gone"
					tools:ignore="ImageContrastCheck" />

				<!-- ==============================================
					 FILE TYPE INDICATOR
					 Icon representing the file category (image,
					 video, audio, document, etc.). Positioned
					 in bottom-start corner with semi-transparent
					 background for better visibility.
					 ============================================== -->
				<ImageView
					android:id="@+id/img_file_type_indicator"
					android:layout_width="@dimen/_20"
					android:layout_height="wrap_content"
					android:layout_gravity="start|bottom"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginBottom="@dimen/_5"
					android:adjustViewBounds="true"
					android:background="@drawable/rounded_transparent_black"
					android:elevation="@dimen/_2"
					android:importantForAccessibility="no"
					android:tint="@color/color_on_primary"
					android:visibility="visible"
					tools:ignore="ImageContrastCheck" />

				<!-- ==============================================
					 PRIVATE FOLDER INDICATOR
					 Lock icon indicating the file is stored in
					 private/protected storage. Positioned in
					 bottom-end corner. Visible when download
					 location is set to private folder.
					 ============================================== -->
				<ImageView
					android:id="@+id/img_private_folder_indicator"
					android:layout_width="@dimen/_20"
					android:layout_height="wrap_content"
					android:layout_gravity="end|bottom"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_5"
					android:adjustViewBounds="true"
					android:background="@drawable/rounded_transparent_black"
					android:elevation="@dimen/_2"
					android:importantForAccessibility="no"
					android:tint="@color/color_on_primary"
					android:visibility="visible"
					tools:ignore="ImageContrastCheck" />

				<!-- ==============================================
					 MEDIA DURATION CONTAINER
					 Container for displaying media duration
					 (audio/video length). Positioned in top-end
					 corner with colored background for prominence.
					 Hidden for non-media files.
					 ============================================== -->
				<LinearLayout
					android:id="@+id/container_media_duration"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_gravity="end"
					android:layout_marginStart="@dimen/_5"
					android:layout_marginTop="@dimen/_5"
					android:layout_marginEnd="@dimen/_5"
					android:layout_marginBottom="@dimen/_5"
					android:background="@drawable/rounded_primary_color"
					android:orientation="vertical"
					android:visibility="gone">

					<!-- ==============================================
						 MEDIA DURATION TEXT
						 Displays formatted media duration (HH:MM:SS)
						 for audio and video files. Uses small font
						 with contrasting text color for readability.
						 ============================================== -->
					<TextView
						android:id="@+id/txt_media_duration"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_1"
						android:layout_marginEnd="@dimen/_5"
						android:layout_marginBottom="@dimen/_1"
						android:fontFamily="@font/application_font_family"
						android:text="@string/title_time_representation"
						android:textColor="@color/color_on_primary"
						android:textSize="@dimen/smaller_text_size"
						android:textStyle="normal"
						tools:ignore="TextContrastCheck" />
				</LinearLayout>

				<!-- ==============================================
					 SELECTION CHECKBOX INDICATOR
					 Checkmark icon used in multi-selection mode.
					 Positioned centrally and shown only when
					 item selection is enabled. Uses secondary
					 color for visual prominence.
					 ============================================== -->
				<ImageView
					android:id="@+id/img_checkbox_selection"
					android:layout_width="@dimen/_30"
					android:layout_height="wrap_content"
					android:layout_alignParentStart="true"
					android:layout_gravity="center_vertical|center_horizontal"
					android:adjustViewBounds="true"
					android:elevation="@dimen/_5"
					android:importantForAccessibility="no"
					android:src="@drawable/media3_icon_check_circle_filled"
					android:tint="@color/color_secondary"
					android:visibility="gone" />

			</androidx.cardview.widget.CardView>

			<!-- ==============================================
				 FILE INFO CONTAINER
				 LinearLayout that holds textual information
				 about the download (filename and metadata).
				 Positioned to the right of the thumbnail.
				 ============================================== -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_centerVertical="true"
				android:layout_marginEnd="@dimen/_8"
				android:layout_toEndOf="@id/container_img_thumbnail"
				android:orientation="vertical">

				<!-- ==============================================
					 FILE NAME AND ACTION ROW
					 RelativeLayout containing the filename and
					 open file button. Ensures proper spacing
					 and alignment between text and action button.
					 ============================================== -->
				<RelativeLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content">

					<!-- ==============================================
						 FILE NAME TEXT
						 Displays the downloaded file name with
						 max 2 lines and ellipsis for overflow.
						 Uses medium font weight for prominence.
						 Automatically adjusts width to accommodate
						 the open button.
						 ============================================== -->
					<TextView
						android:id="@+id/txt_file_name"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_toStartOf="@id/btn_open_download_file"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:gravity="center_vertical"
						android:maxLines="2"
						android:singleLine="false"
						android:text="@string/text_sample_video_file_name"
						android:textColor="@color/color_text_primary"
						android:textFontWeight="500"
						android:textSize="@dimen/normal_text_size_small" />

					<!-- ==============================================
						 OPEN FILE BUTTON
						 Action button for opening the downloaded file
						 with an appropriate application. Positioned
						 at the end of the row with secondary color
						 for visual distinction.
						 ============================================== -->
					<ImageView
						android:id="@+id/btn_open_download_file"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_alignParentEnd="true"
						android:layout_centerVertical="true"
						android:layout_marginStart="@dimen/_5"
						android:adjustViewBounds="true"
						android:importantForAccessibility="no"
						android:src="@drawable/ic_button_open_v2"
						android:tint="@color/color_secondary"
						tools:ignore="ImageContrastCheck" />

				</RelativeLayout>

				<!-- ==============================================
					 METADATA CONTAINER
					 RelativeLayout that displays file metadata
					 (size, date, category) with rounded background.
					 Provides secondary information below filename.
					 ============================================== -->
				<RelativeLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="@dimen/_3"
					android:background="@drawable/rounded_surface_color"
					android:orientation="horizontal">

					<!-- ==============================================
						 FILE INFO TEXT
						 Displays formatted metadata including file
						 size, download date, and file category.
						 Uses italic style and hint color for
						 secondary information presentation.
						 ============================================== -->
					<TextView
						android:id="@+id/txt_file_info"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_alignParentStart="true"
						android:layout_marginStart="@dimen/_5"
						android:layout_marginTop="@dimen/_2"
						android:layout_marginEnd="@dimen/_5"
						android:layout_marginBottom="@dimen/_2"
						android:layout_toStartOf="@+id/img_new_indicator"
						android:ellipsize="end"
						android:fontFamily="@font/application_font_family"
						android:gravity="center_vertical"
						android:singleLine="true"
						android:text="@string/title__"
						android:textColor="@color/color_text_hint"
						android:textFontWeight="400"
						android:textSize="@dimen/smaller_text_size"
						android:textStyle="italic"
						tools:ignore="TextContrastCheck" />

					<!-- ==============================================
						 NEW INDICATOR BADGE
						 Red badge that appears for recently
						 downloaded files. Uses contrasting text
						 color and small padding for compact display.
						 Hidden for older downloads.
						 ============================================== -->
					<ImageView
						android:id="@+id/img_new_indicator"
						android:layout_width="@dimen/_15"
						android:layout_height="wrap_content"
						android:layout_alignParentEnd="true"
						android:layout_centerVertical="true"
						android:layout_marginEnd="@dimen/_5"
						android:adjustViewBounds="true"
						android:importantForAccessibility="yes"
						android:src="@drawable/ic_button_dot"
						android:tint="@color/color_secondary"
						android:visibility="gone"
						tools:ignore="ContentDescription" />
				</RelativeLayout>
			</LinearLayout>
		</RelativeLayout>
	</androidx.cardview.widget.CardView>
</RelativeLayout>