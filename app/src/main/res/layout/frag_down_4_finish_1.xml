<?xml version="1.0" encoding="utf-8"?>
<!--
    EMPTY DOWNLOADS STATE LAYOUT
    This layout displays when no downloads are present, providing users with
    educational resources and navigation options. Features a clean empty state
    design with illustration, informational text, and actionable buttons.
    =========================================================================== -->

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/transparent"
	android:orientation="vertical"
	tools:ignore="UseCompatTextViewDrawableXml">

	<!--
		DOWNLOADS RECYCLERVIEW
		Main container for displaying completed download items when available.
		Hidden by default and shown only when downloads exist. Uses marginless
		design for full-screen utilization with proper clipping configuration.
		===================================================================== -->
	<androidx.recyclerview.widget.RecyclerView
		android:id="@+id/container_download_tasks_finished"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginStart="@dimen/_0"
		android:layout_marginTop="@dimen/_0"
		android:layout_marginEnd="@dimen/_0"
		android:layout_marginBottom="@dimen/_0"
		android:clipChildren="false"
		android:clipToPadding="false"
		android:visibility="gone"
		tools:listitem="@layout/frag_down_4_finish_1_row_1" />

	<!--
		EMPTY STATE CARD
		Centered card displayed when no downloads exist. Provides visual feedback
		that the downloads list is empty and offers guidance on how to get started.
		Uses rounded corners and consistent background coloring.
		========================================================================= -->
	<androidx.cardview.widget.CardView
		android:id="@+id/container_empty_downloads"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_centerInParent="true"
		android:layout_marginStart="@dimen/_10"
		android:layout_marginTop="@dimen/_0"
		android:layout_marginEnd="@dimen/_10"
		android:layout_marginBottom="@dimen/_0"
		android:orientation="vertical"
		android:visibility="visible"
		app:cardBackgroundColor="@color/color_cardview_bg"
		app:cardCornerRadius="@dimen/_10">

		<!-- Empty state content container with vertical stacking -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:orientation="vertical">

			<!--
				EMPTY BOX ILLUSTRATION
				Visual representation of empty state using a box graphic.
				Centered horizontally and vertically with hardware acceleration
				for smooth rendering and performance optimization.
				============================================================== -->
			<ImageView
				android:id="@+id/img_empty_downloads"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_gravity="center_vertical|center_horizontal"
				android:layout_marginTop="@dimen/_10"
				android:adjustViewBounds="true"
				android:hardwareAccelerated="true"
				android:importantForAccessibility="no"
				android:src="@drawable/image_empty_box" />

			<!--
				EMPTY STATE MESSAGE
				Informational text explaining that no downloads exist.
				Uses centered alignment with appropriate margins and typography
				for clear readability and visual hierarchy.
				============================================================== -->
			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_gravity="center_horizontal|center_vertical"
				android:layout_marginStart="@dimen/_25"
				android:layout_marginTop="@dimen/_10"
				android:layout_marginEnd="@dimen/_25"
				android:layout_marginBottom="@dimen/_8"
				android:fontFamily="@font/application_font_family"
				android:gravity="center"
				android:text="@string/title_you_dont_have_any_downloads"
				android:textColor="@color/color_text_primary"
				android:textSize="@dimen/message_text_size" />

			<!--
				HOW TO DOWNLOAD BUTTON
				Primary call-to-action that opens educational content about
				the download process. Uses secondary color scheme with
				question mark icon for intuitive recognition.
				=========================================================== -->
			<RelativeLayout
				android:id="@+id/btn_how_to_download"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_0"
				android:layout_marginEnd="@dimen/_10"
				android:layout_marginBottom="@dimen/_10"
				android:background="@drawable/ic_button_selector_secondary"
				android:clickable="true"
				android:elevation="@dimen/_2"
				tools:ignore="TouchTargetSizeCheck">

				<!-- Button text with integrated question icon -->
				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_centerInParent="true"
					android:layout_margin="@dimen/_7"
					android:drawableStart="@drawable/ic_button_question"
					android:drawablePadding="@dimen/_5"
					android:drawableTint="@color/color_on_secondary"
					android:fontFamily="@font/application_font_family"
					android:gravity="center"
					android:text="@string/title_how_to_download"
					android:textColor="@color/color_on_secondary"
					android:textFontWeight="600"
					android:textSize="@dimen/normal_text_size" />
			</RelativeLayout>

		</LinearLayout>
	</androidx.cardview.widget.CardView>

	<!--
		ACTIVE DOWNLOADS FLOATING ACTION BUTTON
		Floating button that navigates to active downloads screen when
		background downloads are in progress. Initially hidden and shown
		programmatically when active downloads exist. Uses Lottie animation
		for engaging visual feedback.
		=================================================================== -->
	<androidx.cardview.widget.CardView
		android:id="@+id/btn_open_active_downloads"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_alignParentRight="true"
		android:layout_alignParentBottom="true"
		android:layout_gravity="center_vertical|center_horizontal"
		android:layout_marginStart="@dimen/_10"
		android:layout_marginEnd="@dimen/_10"
		android:layout_marginBottom="@dimen/_25"
		android:visibility="gone"
		app:cardBackgroundColor="@color/color_action_bar_bg"
		app:cardCornerRadius="@dimen/_10"
		app:cardElevation="@dimen/_2">

		<!-- Button container with touch feedback selector -->
		<LinearLayout
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:background="@drawable/ic_button_negative_selector"
			android:orientation="vertical">

			<!--
				LOTTIE ANIMATION INDICATOR
				Animated icon showing download activity or video content.
				Uses hardware acceleration and merge paths for optimal
				performance on all Android versions. Auto-plays and loops
				continuously when visible.
				========================================================= -->
			<com.airbnb.lottie.LottieAnimationView
				android:id="@+id/img_open_active_downloads"
				android:layout_width="@dimen/_50"
				android:layout_height="wrap_content"
				android:layout_gravity="right"
				android:layout_margin="@dimen/_5"
				android:adjustViewBounds="true"
				android:hardwareAccelerated="true"
				android:importantForAccessibility="no"
				android:layerType="hardware"
				app:lottie_autoPlay="true"
				app:lottie_enableMergePathsForKitKatAndAbove="true"
				app:lottie_loop="true"
				app:lottie_rawRes="@raw/animation_videos_found"
				tools:ignore="ImageContrastCheck" />
		</LinearLayout>
	</androidx.cardview.widget.CardView>

</RelativeLayout>