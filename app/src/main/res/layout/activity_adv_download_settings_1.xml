<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@drawable/ic_background_gradient"
	android:orientation="vertical"
	tools:context="app.ui.main.fragments.settings.activities.downloads.AdvDownloadSettingsActivity"
	tools:ignore="UseCompatTextViewDrawableXml,UseAppTint,VisualLintBounds">

	<androidx.cardview.widget.CardView
		android:id="@+id/card_actionbar"
		android:layout_width="match_parent"
		android:layout_height="@dimen/_50"
		android:layout_alignParentTop="true"
		android:layout_marginStart="@dimen/_5"
		android:layout_marginTop="@dimen/_10"
		android:layout_marginEnd="@dimen/_5"
		android:layout_marginBottom="@dimen/_8"
		app:cardBackgroundColor="@color/color_actionbar_title_bg"
		app:cardCornerRadius="@dimen/_10">

		<RelativeLayout
			android:layout_width="match_parent"
			android:layout_height="match_parent">

			<RelativeLayout
				android:id="@+id/btn_left_actionbar"
				android:layout_width="@dimen/_50"
				android:layout_height="match_parent"
				android:background="@drawable/ic_button_negative_selector"
				android:clickable="true"
				tools:ignore="SpeakableTextPresentCheck">

				<ImageView
					android:id="@+id/img_back"
					android:layout_width="@dimen/_30"
					android:layout_height="wrap_content"
					android:layout_centerInParent="true"
					android:adjustViewBounds="true"
					android:importantForAccessibility="no"
					android:src="@drawable/ic_button_actionbar_back"
					android:tint="@color/color_secondary"
					tools:ignore="ImageContrastCheck" />
			</RelativeLayout>

			<TextView
				android:id="@+id/txt_title"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:layout_marginStart="@dimen/_10"
				android:layout_marginTop="@dimen/_0"
				android:layout_marginEnd="@dimen/_10"
				android:layout_marginBottom="@dimen/_0"
				android:layout_toEndOf="@id/btn_left_actionbar"
				android:ellipsize="end"
				android:fontFamily="@font/font_family_bold"
				android:gravity="center_vertical"
				android:maxLines="1"
				android:text="@string/title_download_settings"
				android:textSize="@dimen/title_text_size" />

		</RelativeLayout>
	</androidx.cardview.widget.CardView>

	<ScrollView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_below="@+id/card_actionbar"
		android:orientation="vertical"
		tools:ignore="UseCompatTextViewDrawableXml,UseAppTint,TooManyViews">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<androidx.cardview.widget.CardView
				android:id="@+id/card_settings"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginStart="@dimen/_5"
				android:layout_marginTop="@dimen/_2"
				android:layout_marginEnd="@dimen/_5"
				android:layout_marginBottom="@dimen/_10"
				android:orientation="vertical"
				app:cardBackgroundColor="@color/color_cardview_bg"
				app:cardCornerRadius="@dimen/_10">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">

					<LinearLayout
						android:id="@+id/btn_download_dir"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_10"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:id="@+id/txt_download_dir"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_folder"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_default_download_folder"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_hide_notifications"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:id="@+id/txt_hide_notifications"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_notifications"
							android:drawableEnd="@drawable/ic_button_unchecked_circle_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_hide_task_notifications"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_hide_thumbnails"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:id="@+id/txt_hide_thumbnails"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_thumbnail"
							android:drawableEnd="@drawable/ic_button_unchecked_circle_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_hide_tasks_thumbnail"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<View
						android:layout_width="match_parent"
						android:layout_height="@dimen/_1"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_5"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_5"
						android:background="@color/transparent_dark" />

					<LinearLayout
						android:id="@+id/btn_wifi_only"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:id="@+id/txt_wifi_only"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_wifi_signal"
							android:drawableEnd="@drawable/ic_button_unchecked_circle_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_wifi_only_download"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_single_click"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:id="@+id/txt_single_click"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_single_click"
							android:drawableEnd="@drawable/ic_button_unchecked_circle_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_single_click_open"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_notification_sound"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:id="@+id/txt_notification_sound"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_audio"
							android:drawableEnd="@drawable/ic_button_unchecked_circle_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_play_notification_sound"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<View
						android:layout_width="match_parent"
						android:layout_height="@dimen/_1"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_5"
						android:layout_marginEnd="@dimen/_5"
						android:layout_marginBottom="@dimen/_5"
						android:background="@color/transparent_dark" />

					<LinearLayout
						android:id="@+id/btn_auto_resume"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:id="@+id/txt_auto_resume"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_stop_limit"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_max_auto_resume_limit"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_smart_catalog"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:id="@+id/txt_smart_catalog"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_smart"
							android:drawableEnd="@drawable/ic_button_unchecked_circle_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_auto_smart_catalog_gen"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<View
						android:layout_width="match_parent"
						android:layout_height="@dimen/_1"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_5"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_5"
						android:background="@color/transparent_dark" />

					<LinearLayout
						android:id="@+id/btn_auto_thread"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:id="@+id/txt_auto_thread"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_process"
							android:drawableEnd="@drawable/ic_button_unchecked_circle_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_auto_download_thread_selection"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_max_parallel"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:id="@+id/txt_max_parallel"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_stop_limit"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_max_parallel_tasks"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_user_agent"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_0"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:id="@+id/txt_user_agent"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_user_agent"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/text_download_useragent"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/btn_speed_limit"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_0"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_10"
						android:background="@drawable/ic_button_negative_selector"
						android:clickable="true"
						android:orientation="vertical"
						tools:ignore="TouchTargetSizeCheck">

						<TextView
							android:id="@+id/txt_speed_limit"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_8"
							android:drawableStart="@drawable/ic_button_speed"
							android:drawableEnd="@drawable/ic_button_open_small"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_secondary"
							android:fontFamily="@font/font_family_regular"
							android:text="@string/title_max_download_speed_limit"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

				</LinearLayout>
			</androidx.cardview.widget.CardView>

			<androidx.cardview.widget.CardView
				android:id="@+id/card_reset"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginStart="@dimen/_5"
				android:layout_marginTop="@dimen/_0"
				android:layout_marginEnd="@dimen/_5"
				android:layout_marginBottom="@dimen/_10"
				android:orientation="vertical"
				app:cardBackgroundColor="@color/color_cardview_bg"
				app:cardCornerRadius="@dimen/_10">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:orientation="vertical">

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:background="@color/color_cardview_title_bg"
						android:orientation="vertical"
						tools:ignore="TooManyViews">

						<TextView
							android:id="@+id/txt_reset_title"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_margin="@dimen/_10"
							android:ellipsize="end"
							android:fontFamily="@font/font_family_semibold"
							android:gravity="center"
							android:maxLines="1"
							android:text="@string/title_reset_settings"
							android:textColor="@color/color_text_primary"
							android:textSize="@dimen/normal_text_size" />
					</LinearLayout>

					<TextView
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_10"
						android:layout_marginEnd="@dimen/_10"
						android:autoLink="web"
						android:fontFamily="@font/font_family_regular"
						android:gravity="center"
						android:text="@string/text_reset_download_settings"
						android:textColor="@color/color_text_primary"
						android:textSize="@dimen/message_text_size"
						tools:ignore="TextContrastCheck" />

					<RelativeLayout
						android:id="@+id/btn_reset"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/_10"
						android:layout_marginTop="@dimen/_10"
						android:layout_marginEnd="@dimen/_10"
						android:layout_marginBottom="@dimen/_10"
						android:background="@drawable/ic_button_selector_secondary"
						android:clickable="true"
						android:elevation="@dimen/_2"
						tools:ignore="TouchTargetSizeCheck,DuplicateSpeakableTextCheck">

						<TextView
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_centerInParent="true"
							android:layout_margin="@dimen/_7"
							android:drawableStart="@drawable/ic_button_clear"
							android:drawablePadding="@dimen/_5"
							android:drawableTint="@color/color_on_secondary"
							android:fontFamily="@font/font_family_semibold"
							android:gravity="center"
							android:text="@string/title_reset_settings"
							android:textColor="@color/color_on_secondary"
							android:textSize="@dimen/normal_text_size" />
					</RelativeLayout>

				</LinearLayout>
			</androidx.cardview.widget.CardView>
		</LinearLayout>
	</ScrollView>
</RelativeLayout>